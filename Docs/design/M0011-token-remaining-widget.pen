          "y": 328,
          "fill": "#71717A",
          "content": "WHAT GETS INSTALLED (per account)",
          "fontFamily": "Inter",
          "fontSize": 10,
          "fontWeight": "700"
        },
        {
          "type": "rectangle",
          "cornerRadius": 6,
          "id": "C4XJYK",
          "x": 22,
          "y": 348,
          "fill": "#FAFAFA",
          "width": 716,
          "height": 74,
