          }
        },
        {
          "type": "text",
          "id": "j3FP29",
          "x": 34,
          "y": 356,
          "fill": "#52525B",
          "content": "1. Backup settings.json → %LOCALAPPDATA%\\AgentZeroLite\\statusline-backup\\<acct>\\settings.json.<ts>.bak",
          "fontFamily": "Inter",
          "fontSize": 9,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "T77yaJ",
          "x": 34,
          "y": 370,
          "fill": "#52525B",
          "content": "2. Replace statusLine.command with az-hud-wrapper.cmd --account <acct> [--pipe <existing-cmd>]",
          "fontFamily": "Inter",
          "fontSize": 9,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "b8EqQh",
          "x": 34,
          "y": 384,
          "fill": "#52525B",
          "content": "3. Wrapper writes per-tick snapshot to %LOCALAPPDATA%\\AgentZeroLite\\cc-hud-snapshots\\<acct>.json",
          "fontFamily": "Inter",
          "fontSize": 9,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "q9IadO",
          "x": 34,
          "y": 398,
          "fill": "#52525B",
          "content": "4. claude-hud (or other statusLine) preserved via --pipe, stdout forwarded transparently",
          "fontFamily": "Inter",
          "fontSize": 9,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "Q8B8Ax",
