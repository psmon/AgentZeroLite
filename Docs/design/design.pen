            },
            {
              "type": "text",
              "id": "hOpE1",
              "name": "stS",
              "fill": "#7CFDB0",
              "content": "State",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "bold"
            },
            {
              "type": "text",
              "id": "cMg7v",
              "name": "stS1",
              "fill": "#D4D4D4",
              "content": "  Dictionary<string, IActorRef> _workspaces",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "j9QF5",
              "name": "stS2",
              "fill": "#D4D4D4",
              "content": "  IActorRef? _botActor",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "vF9b4",
              "name": "stS3",
              "fill": "#D4D4D4",
              "content": "  string?   _activeWorkspace, _activeTerminalId",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "P1mFZ",
              "name": "stRec",
              "fill": "#7CFDB0",
              "content": "Receives (key)",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "bold"
            },
            {
              "type": "text",
              "id": "wLFRj",
              "name": "stR1",
              "fill": "#D4D4D4",
              "content": "  RegisterWorkspace → spawn WorkspaceActor child",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "D8wGr",
              "name": "stR2",
              "fill": "#D4D4D4",
              "content": "  CreateBot → spawn AgentBotActor child (or return existing)",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "Z5UQu",
              "name": "stR3",
              "fill": "#D4D4D4",
