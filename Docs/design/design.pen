              "name": "treeT",
              "fill": "#7CFDB0",
              "content": "Actor hierarchy",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "bold"
            },
            {
              "type": "text",
              "id": "YkiPK",
              "name": "tree1",
              "fill": "#D4D4D4",
              "content": "/user/stage              StageActor   (singleton, supervisor)",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "79OlG",
              "name": "tree2",
              "fill": "#3794FF",
              "content": "  ├── /bot               AgentBotActor   (0..1, gateway)",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "ecLPj",
              "name": "tree3",
              "fill": "#C586C0",
              "content": "  │     └── /reactor     AgentReactorActor   (lazy child)",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "lMN0a",
              "name": "tree4",
              "fill": "#4EC9B0",
              "content": "  └── /ws-<name>         WorkspaceActor   (N, per-folder)",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "UIObT",
              "name": "tree5",
              "fill": "#DCDCAA",
              "content": "        └── /term-<id>   TerminalActor   (N, ConPTY wrapper)",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "DH0s9",
              "name": "treeNote",
              "fill": "#858585",
              "content": "Names sanitized via ActorNameSanitizer.Safe(...) — '/'· ':' · spaces stripped.",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal",
              "fontStyle": "italic"
            }
          ]
        },
        {
          "type": "frame",
          "id": "G6uOI",
          "x": 600,
          "y": 24,
          "name": "supBox",
          "width": 560,
          "height": 300,
          "fill": "#0D0D1A",
          "cornerRadius": 6,
          "stroke": {
            "thickness": 1,
            "fill": "#3E3E42"
          },
          "layout": "vertical",
          "gap": 8,
          "padding": 14,
          "children": [
            {
              "type": "text",
              "id": "lw2Hv",
              "name": "supT",
              "fill": "#7CFDB0",
              "content": "Supervisor strategies",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "bold"
            },
            {
              "type": "text",
              "id": "7n3mD",
              "name": "sup1",
              "fill": "#3794FF",
              "content": "StageActor (5 retries / 1 min):",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "bold"
            },
            {
              "type": "text",
              "id": "wJkwp",
              "name": "sup1a",
              "fill": "#D4D4D4",
              "content": "  ArgumentException     → Resume",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "jjAlP",
              "name": "sup1b",
              "fill": "#D4D4D4",
              "content": "  NullReferenceException → Restart",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "SUB28",
              "name": "sup1c",
              "fill": "#D4D4D4",
              "content": "  *                     → Escalate",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "pDr26",
              "name": "sup2",
              "fill": "#4EC9B0",
              "content": "WorkspaceActor (3 retries / 1 min):",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "bold"
            },
            {
              "type": "text",
              "id": "Kml7M",
              "name": "sup2a",
              "fill": "#D4D4D4",
              "content": "  ObjectDisposedException → Stop  (pipe gone, cannot restart)",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "YQvYz",
              "name": "sup2b",
              "fill": "#D4D4D4",
              "content": "  IOException             → Stop",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "dwuTr",
              "name": "sup2c",
              "fill": "#D4D4D4",
              "content": "  *                       → Restart",
              "fontFamily": "Inter",
              "fontSize": 10,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "MfVyo",
          "x": 1180,
          "y": 24,
          "name": "miniBox",
          "width": 676,
          "height": 300,
          "fill": "#0D0D1A",
          "cornerRadius": 6,
          "stroke": {
            "thickness": 1,
            "fill": "#DCDCAA"
          },
          "layout": "vertical",
          "gap": 6,
          "padding": 14,
          "children": [
            {
              "type": "text",
              "id": "WodPk",
              "name": "miniT",
              "fill": "#DCDCAA",
              "content": "Mailbox / message single-threading invariant",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "bold"
            },
            {
              "type": "text",
              "id": "F9dOz",
              "name": "mini1",
              "fill": "#D4D4D4",
              "content": "• Each actor processes one message at a time (Akka mailbox).",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "drNpd",
              "name": "mini2",
              "fill": "#D4D4D4",
              "content": "• Reactor's loop runs on Task.Run, but EVERY callback funnels through",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "OzICa",
              "name": "mini3",
              "fill": "#D4D4D4",
              "content": "  Self.Tell(internal record) → mutations stay single-threaded.",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "P0XHu",
              "name": "mini4",
              "fill": "#D4D4D4",
              "content": "• PipeTo(Self) carries Run completion/failure back as messages.",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "wOfTq",
              "name": "mini5",
              "fill": "#D4D4D4",
              "content": "• UI thread is Tell-only; UI callbacks delivered to dispatcher by AgentBotActor.",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
