                                    { "type": "text", "id": "cmpR2", "content": "• handshakes + targeted prompts",     "fill": "#D4D4D4", "fontFamily": "Inter", "fontSize": 10 },
                                    { "type": "text", "id": "cmpR3", "content": "• waits, reads, decides next step",   "fill": "#D4D4D4", "fontFamily": "Inter", "fontSize": 10 },
                                    { "type": "text", "id": "cmpR4", "content": "• routes between specialists",        "fill": "#D4D4D4", "fontFamily": "Inter", "fontSize": 10 },
