<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:idc="using:Dock.Avalonia.Controls"
        xmlns:vm="using:AgentZeroAvalonia.ViewModels"
        x:Class="AgentZeroAvalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d"
        Width="1100" Height="720"
        MinWidth="720" MinHeight="480"
        Title="AgentZero Lite (Avalonia)">

    <DockPanel LastChildFill="True">

        <!-- 상단 메뉴 -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_파일">
                <MenuItem Header="새 터미널" Command="{Binding NewTerminalCommand}" />
                <Separator />
                <MenuItem Header="종료" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_도움말">
                <MenuItem Header="정보" Click="OnAboutClick" />
            </MenuItem>
        </Menu>

        <!-- 본문: 도킹 레이아웃 (채팅 / 터미널 도큐먼트) -->
        <idc:DockControl Layout="{Binding Layout}" />

    </DockPanel>
</Window>
