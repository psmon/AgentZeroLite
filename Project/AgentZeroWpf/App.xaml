<Application x:Class="AgentZeroWpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- ===== Global Dark ScrollBar Styles ===== -->

        <!-- Thumb (draggable part) -->
        <Style x:Key="CyberScrollThumb" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBd" CornerRadius="0"
                                Background="#3E3E42" BorderThickness="0"
                                Margin="1">
                            <Rectangle Width="2" Height="14" Fill="#6E6E71"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       RadiusX="1" RadiusY="1" Opacity="0.6"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#505054" Offset="0"/>
                                            <GradientStop Color="#45454A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3794FF" Offset="0"/>
                                            <GradientStop Color="#264F78" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- RepeatButton for track area (transparent) -->
        <Style x:Key="CyberScrollRepeatButton" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Arrow RepeatButton -->
        <Style x:Key="CyberScrollArrowButton" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="ArrowBd" Background="#252526" Height="14" Width="14">
                            <Path x:Name="ArrowPath" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Fill="#858585" Data="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ArrowPath" Property="Fill" Value="#3794FF"/>
                                <Setter TargetName="ArrowBd" Property="Background" Value="#333337"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ArrowPath" Property="Fill" Value="#C586C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical ScrollBar -->
        <ControlTemplate x:Key="CyberVerticalScrollBar" TargetType="ScrollBar">
            <Grid Background="#1E1E1E">
                <Grid.RowDefinitions>
                    <RowDefinition MaxHeight="14"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition MaxHeight="14"/>
                </Grid.RowDefinitions>
                <RepeatButton Grid.Row="0" Style="{StaticResource CyberScrollArrowButton}"
                              Command="ScrollBar.LineUpCommand"
                              Content="M 0,4 L 4,0 L 8,4 Z"/>
                <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource CyberScrollRepeatButton}"
                                      Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource CyberScrollThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource CyberScrollRepeatButton}"
                                      Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Row="2" Style="{StaticResource CyberScrollArrowButton}"
                              Command="ScrollBar.LineDownCommand"
                              Content="M 0,0 L 4,4 L 8,0 Z"/>
                <Rectangle Grid.RowSpan="3" Width="1" HorizontalAlignment="Left" IsHitTestVisible="False"
                           Opacity="0.15">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#4EC9B0" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>
        </ControlTemplate>

        <!-- Horizontal ScrollBar -->
        <ControlTemplate x:Key="CyberHorizontalScrollBar" TargetType="ScrollBar">
            <Grid Background="#1E1E1E">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MaxWidth="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition MaxWidth="14"/>
                </Grid.ColumnDefinitions>
                <RepeatButton Grid.Column="0" Style="{StaticResource CyberScrollArrowButton}"
                              Command="ScrollBar.LineLeftCommand"
                              Content="M 4,0 L 0,4 L 4,8 Z"/>
                <Track x:Name="PART_Track" Grid.Column="1" IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource CyberScrollRepeatButton}"
                                      Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource CyberScrollThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource CyberScrollRepeatButton}"
                                      Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Column="2" Style="{StaticResource CyberScrollArrowButton}"
                              Command="ScrollBar.LineRightCommand"
                              Content="M 0,0 L 4,4 L 0,8 Z"/>
                <Rectangle Grid.ColumnSpan="3" Height="1" VerticalAlignment="Top" IsHitTestVisible="False"
                           Opacity="0.15">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#3794FF" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>
        </ControlTemplate>

        <!-- Implicit ScrollBar style (global) -->
        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="14"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource CyberVerticalScrollBar}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="14"/>
                    <Setter Property="Template" Value="{StaticResource CyberHorizontalScrollBar}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
