<Window x:Class="AgentZeroWpf.UI.APP.AgentBotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="clr-namespace:AgentZeroWpf.UI.Components"
        xmlns:voice="clr-namespace:AgentZeroWpf.UI.Components.Voice"
        Title="AgentZero — BOT"
        Width="420" Height="600"
        MinWidth="320" MinHeight="400"
        WindowStyle="None"
        Background="#1E1E1E"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="False"
        ShowActivated="False"
        Icon="/agentzero.ico"
        StateChanged="OnWindowStateChanged">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDeep"       Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#252526"/>
        <SolidColorBrush x:Key="BgToolbar"    Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderDim"    Color="#3E3E42"/>
        <SolidColorBrush x:Key="CyanBrush"    Color="#3794FF"/>
        <SolidColorBrush x:Key="MagentaBrush" Color="#C586C0"/>
        <SolidColorBrush x:Key="PurpleBrush"  Color="#4EC9B0"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#D4D4D4"/>
        <SolidColorBrush x:Key="TextDim"      Color="#858585"/>
        <SolidColorBrush x:Key="InputBg"      Color="#1F1F1F"/>
        <SolidColorBrush x:Key="InputBorder"  Color="#3E3E42"/>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#383B3F"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="botRoot">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="titleBarRow" Height="32"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/> <!-- Session info -->
            <RowDefinition Height="*"/>    <!-- Chat messages -->
            <RowDefinition Height="Auto"/> <!-- Slash popup -->
            <RowDefinition Height="Auto"/> <!-- Clipboard tag -->
            <RowDefinition Height="Auto"/> <!-- MD file attachment tags -->
            <RowDefinition Height="Auto"/> <!-- Input resize handle -->
            <RowDefinition Height="Auto"/> <!-- Input area -->
        </Grid.RowDefinitions>

        <!-- Approval Toast (overlay, above chat) -->
        <components:ApprovalToast x:Name="approvalToast" Grid.Row="2"
                                   HorizontalAlignment="Stretch" VerticalAlignment="Top"
                                   Margin="8,8,8,0" Panel.ZIndex="100"/>

        <!-- Mode change toast (overlay, top of chat) -->
        <Border x:Name="pnlModeToast" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Top"
                Background="#E0252526" CornerRadius="4" Padding="16,6" Margin="0,8,0,0"
                Panel.ZIndex="99" Visibility="Collapsed">
            <TextBlock x:Name="txtModeToast" FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
        </Border>


        <!-- ===== Title Bar ===== -->
        <Border Grid.Row="0" MouseLeftButtonDown="OnTitleBarMouseDown">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E1E1E" Offset="0"/>
                    <GradientStop Color="#2D2D30" Offset="0.5"/>
                    <GradientStop Color="#1E1E1E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel Margin="8,0">
                <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{StaticResource CyanBrush}" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Text="AGENT BOT" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                           Foreground="{StaticResource CyanBrush}" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="&#xE8A7;" Style="{StaticResource TitleBarButton}"
                            ToolTip="메인창에 임베드 (Ctrl+Shift+`)"
                            Click="OnEmbedClick"/>
                    <Button Content="&#xE921;" Style="{StaticResource TitleBarButton}"
                            Click="OnMinimizeClick"/>
                    <Button x:Name="MaxRestoreButton" Content="&#xE922;" Style="{StaticResource TitleBarButton}"
                            Click="OnMaximizeClick"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource TitleBarCloseButton}"
                            Click="OnCloseClick"/>
                </StackPanel>
                <Rectangle/>
            </DockPanel>
        </Border>

        <!-- ===== Session Info Bar (2-row: session info + collapsible options) ===== -->
        <StackPanel Grid.Row="1">
            <!-- Row A: Session info + toggle button -->
            <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderDim}"
                    BorderThickness="0,0,0,1" Padding="10,4">
                <DockPanel>
                    <Button x:Name="btnToggleOptions" DockPanel.Dock="Right"
                            Content="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Style="{StaticResource TitleBarButton}" Width="28" Height="22"
                            ToolTip="Toggle options panel"
                            Click="OnToggleOptionsClick"/>
                    <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource PurpleBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtSessionInfo"
                               FontFamily="Consolas" FontSize="11"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis">
                        <Run Text="No Terminal Session" Foreground="{StaticResource TextDim}"/>
                    </TextBlock>
                </DockPanel>
            </Border>

            <!-- Row B: Options (collapsible) -->
            <Border x:Name="pnlOptionsBar" Background="{StaticResource BgToolbar}"
                    BorderBrush="{StaticResource BorderDim}" BorderThickness="0,0,0,1"
                    Padding="10,3">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Delay" FontFamily="Consolas" FontSize="10"
                               Foreground="{StaticResource TextDim}" VerticalAlignment="Center"
                               Margin="0,0,2,0"/>
                    <TextBox x:Name="txtAutoApproveDelay" Width="28" Height="18"
                             FontFamily="Consolas" FontSize="10" Text="5"
                             Background="{StaticResource InputBg}" Foreground="{StaticResource TextPrimary}"
                             BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                             ToolTip="Auto-approve delay in seconds (0 = instant)"
                             TextChanged="OnAutoApproveDelayChanged"/>
                    <TextBlock Text="s" FontFamily="Consolas" FontSize="10"
                               Foreground="{StaticResource TextDim}" VerticalAlignment="Center"
                               Margin="1,0,6,0"/>
                    <CheckBox x:Name="chkAutoApprove"
                              Content="Auto" FontFamily="Consolas" FontSize="10"
                              Foreground="{StaticResource TextDim}" VerticalAlignment="Center"
                              ToolTip="Auto-approve terminal prompts"
                              Checked="OnAutoApproveChanged" Unchecked="OnAutoApproveChanged"/>
                    <Border Width="1" Background="{StaticResource BorderDim}" Margin="6,2"/>
                    <CheckBox x:Name="chkThinking" IsChecked="True"
                              Content="Thinking" FontFamily="Consolas" FontSize="10"
                              Foreground="#CCAA44" VerticalAlignment="Center"
                              ToolTip="ON: ReAct planning (Thinking→Acting→Waiting) / OFF: Legacy FnCall loop"/>
                    <Border Width="1" Background="{StaticResource BorderDim}" Margin="6,2"/>
                    <CheckBox x:Name="chkHideSysMsg" IsChecked="True"
                              Content="Hide SysMsg" FontFamily="Consolas" FontSize="10"
                              Foreground="{StaticResource TextDim}" VerticalAlignment="Center"
                              ToolTip="Hide system messages (Auto-Approve, etc.)"/>
                </WrapPanel>
            </Border>
        </StackPanel>

        <!-- ===== Chat Messages ===== -->
        <Border Grid.Row="2" Background="{StaticResource BgDeep}">
            <ScrollViewer x:Name="scrollChat" VerticalScrollBarVisibility="Auto"
                          Padding="8,6">
                <StackPanel x:Name="pnlMessages" Margin="0,4"/>
            </ScrollViewer>
        </Border>

        <!-- ===== Slash Command Popup ===== -->
        <Border x:Name="pnlSlashPopup" Grid.Row="3" Background="{StaticResource BgToolbar}"
                BorderBrush="{StaticResource BorderDim}" BorderThickness="0,1,0,0"
                Visibility="Collapsed" MaxHeight="200">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="pnlSlashItems"/>
            </ScrollViewer>
        </Border>

        <!-- ===== Clipboard Attachment Tag ===== -->
        <Border x:Name="pnlClipboardTag" Grid.Row="4" Background="{StaticResource BgToolbar}"
                BorderBrush="{StaticResource BorderDim}" BorderThickness="0,1,0,0"
                Padding="8,4" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Border Background="{StaticResource InputBg}" CornerRadius="0" Padding="8,3" Cursor="Hand"
                        MouseLeftButtonDown="OnClipboardTagClick">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{StaticResource CyanBrush}" VerticalAlignment="Center"
                                   Margin="0,0,5,0"/>
                        <TextBlock x:Name="txtClipboardTag" Text="[클립보드 0자]"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="{StaticResource CyanBrush}" VerticalAlignment="Center"/>
                        <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                Foreground="{StaticResource TextDim}" Background="Transparent"
                                BorderThickness="0" Padding="6,0,0,0" Cursor="Hand"
                                VerticalAlignment="Center" Click="OnClipboardTagRemove"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== MD File Attachment Tags ===== -->
        <Border x:Name="pnlMdFileTags" Grid.Row="5" Background="{StaticResource BgToolbar}"
                BorderBrush="{StaticResource BorderDim}" BorderThickness="0,1,0,0"
                Padding="8,4" Visibility="Collapsed">
            <StackPanel x:Name="pnlMdFileItems" Orientation="Horizontal"/>
        </Border>

        <!-- ===== MD File Picker Popup ===== -->
        <Popup x:Name="popupMdPicker" Placement="Top" StaysOpen="False"
               PlacementTarget="{Binding ElementName=btnPlus}" AllowsTransparency="True">
            <Border Background="{StaticResource BgToolbar}" BorderBrush="{StaticResource BorderDim}"
                    BorderThickness="1" CornerRadius="4" Padding="4" MinWidth="280" MaxHeight="300">
                <StackPanel>
                    <TextBox x:Name="txtMdFilter" Background="{StaticResource InputBg}"
                             BorderBrush="{StaticResource InputBorder}" BorderThickness="1"
                             Foreground="{StaticResource TextPrimary}" CaretBrush="{StaticResource CyanBrush}"
                             FontFamily="Consolas" FontSize="11" Padding="6,3"/>
                    <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                        <StackPanel x:Name="pnlMdFileList"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Popup>

        <!-- ===== Input Resize Handle ===== -->
        <Border Grid.Row="6" Height="6" Background="{StaticResource BgToolbar}"
                BorderBrush="{StaticResource BorderDim}" BorderThickness="0,1,0,0"
                Cursor="SizeNS"
                MouseLeftButtonDown="OnResizeHandleMouseDown"
                MouseMove="OnResizeHandleMouseMove"
                MouseLeftButtonUp="OnResizeHandleMouseUp">
            <Rectangle Height="2" Width="32" Fill="{StaticResource BorderDim}"
                       RadiusX="1" RadiusY="1" HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- ===== Input Area ===== -->
        <Border Grid.Row="7" Background="{StaticResource BgToolbar}"
                BorderBrush="{StaticResource BorderDim}" BorderThickness="0,1,0,0"
                Padding="8,6"
                KeyboardNavigation.TabNavigation="None"
                KeyboardNavigation.DirectionalNavigation="None">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Mini key buttons (collapsible, default hidden) -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <StackPanel.Resources>
                        <Style x:Key="MiniKeyButton" TargetType="Button">
                            <Setter Property="MinWidth" Value="26"/>
                            <Setter Property="Height" Value="22"/>
                            <Setter Property="Margin" Value="0,0,3,0"/>
                            <Setter Property="Padding" Value="6,0"/>
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            <Setter Property="Background" Value="{StaticResource InputBg}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2D2D30"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#264F78"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>
                    <!-- Mode toggle button (same size as arrow keys) -->
                    <Button x:Name="btnCycleMode" Content="CHT" Tag="mode"
                            Style="{StaticResource MiniKeyButton}" FontSize="9" FontWeight="Bold"
                            Click="OnCycleModeClick" ToolTip="Switch mode (Shift+Tab)"/>
                    <!-- AIMODE session reset (visible only in AI mode) -->
                    <Button x:Name="btnAiNewSession" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource MiniKeyButton}" FontSize="11"
                            Visibility="Collapsed"
                            Click="OnAiNewSessionClick" ToolTip="New AI session (clear KV cache + introductions)"/>
                    <!-- Voice AUTO toggle: ON listens with VAD auto-segment, OFF blocks mic entirely.
                         Sensitivity / model / device come from the Voice Test settings (shared store). -->
                    <Button x:Name="btnVoiceMic" Content="&#xE720;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource MiniKeyButton}" FontSize="12"
                            Click="OnVoiceMicToggle" ToolTip="Voice AUTO (mic) — toggle live transcription"/>
                    <!-- Virtual voice injector — silent test mode. Synthesises the typed
                         text via TTS and plays it through the default speaker so the
                         active mic re-captures it through the OS audio loop. Validates
                         the full STT path end-to-end without needing a human speaker. -->
                    <Button x:Name="btnVoiceTestToggle" Content="&#xE768;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource MiniKeyButton}" FontSize="11"
                            Click="OnVoiceTestToggle"
                            ToolTip="Virtual voice (test) — type text → TTS plays through speaker → mic re-captures it"/>
                    <Border Width="1" Margin="4,2" Background="{StaticResource BorderDim}"/>
                    <!-- Key panel toggle -->
                    <Button x:Name="btnToggleKeys" Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource MiniKeyButton}" FontSize="10"
                            Click="OnToggleKeysClick" ToolTip="Toggle key buttons"/>
                    <!-- Collapsible key buttons -->
                    <StackPanel x:Name="pnlMiniKeys" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="◀" Tag="left"  Style="{StaticResource MiniKeyButton}" Click="OnMiniKeyClick" ToolTip="Left"/>
                        <Button Content="▲" Tag="up"    Style="{StaticResource MiniKeyButton}" Click="OnMiniKeyClick" ToolTip="Up"/>
                        <Button Content="▼" Tag="down"  Style="{StaticResource MiniKeyButton}" Click="OnMiniKeyClick" ToolTip="Down"/>
                        <Button Content="▶" Tag="right" Style="{StaticResource MiniKeyButton}" Click="OnMiniKeyClick" ToolTip="Right"/>
                        <Border Width="1" Margin="4,2" Background="{StaticResource BorderDim}"/>
                        <Button Content="Enter" Tag="enter" Style="{StaticResource MiniKeyButton}" Click="OnMiniKeyClick" ToolTip="Enter"/>
                        <Button Content="Tab"   Tag="tab"   Style="{StaticResource MiniKeyButton}" Click="OnMiniKeyClick" ToolTip="Tab"/>
                        <Button Content="Esc"   Tag="esc"   Style="{StaticResource MiniKeyButton}" Click="OnMiniKeyClick" ToolTip="Escape"/>
                    </StackPanel>
                </StackPanel>

                <!-- ===== Voice strips container (waveform + virtual voice test) ===== -->
                <StackPanel Grid.Row="1" Orientation="Vertical">
                <!-- ===== Voice waveform strip (only visible while mic is ON) ===== -->
                <Border x:Name="pnlVoiceWaveStrip"
                        Background="#1A1F26" CornerRadius="3"
                        Padding="6,2" Margin="0,0,0,4"
                        Visibility="Collapsed">
                    <DockPanel LastChildFill="True">
                        <TextBlock x:Name="txtVoiceStatus" DockPanel.Dock="Left"
                                   Text="Listening…" FontFamily="Consolas" FontSize="10"
                                   Foreground="{StaticResource TextDim}" VerticalAlignment="Center"
                                   Margin="2,0,8,0"/>
                        <Button x:Name="btnVoiceCancelInflight" DockPanel.Dock="Right"
                                Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextDim}" Cursor="Hand"
                                Padding="4,0" VerticalAlignment="Center"
                                Visibility="Collapsed"
                                Click="OnVoiceCancelInflight"
                                ToolTip="Cancel current transcription"/>
                        <voice:VoiceWaveformIndicator x:Name="voiceWave"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- ===== Virtual voice test strip (silent test mode) =====
                     Type text → TTS synthesises → plays through speaker → mic
                     re-captures it. Use to validate the STT path end-to-end
                     without a human speaker. Mic must be ON for round-trip. -->
                <Border x:Name="pnlVoiceTestStrip"
                        Background="#1A1F26" CornerRadius="3"
                        Padding="6,4" Margin="0,0,0,4"
                        Visibility="Collapsed">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="🧪" FontSize="11" VerticalAlignment="Center"
                                   Margin="2,0,6,0" ToolTip="Virtual voice test — TTS → speaker → mic"/>
                        <Button x:Name="btnVoiceTestSpeak" DockPanel.Dock="Right"
                                Content="Speak" FontSize="10"
                                Style="{StaticResource MiniKeyButton}"
                                Margin="6,0,0,0" Padding="8,2"
                                Click="OnVoiceTestSpeak"
                                ToolTip="Synthesise the text and play through speaker (Enter)"/>
                        <TextBlock x:Name="txtVoiceTestStatus" DockPanel.Dock="Right"
                                   Text="" FontFamily="Consolas" FontSize="9"
                                   Foreground="{StaticResource TextDim}"
                                   VerticalAlignment="Center" Margin="6,0,4,0"/>
                        <TextBox x:Name="txtVoiceTestInput"
                                 FontSize="11" FontFamily="Consolas"
                                 Background="#0F141A" Foreground="{StaticResource TextLight}"
                                 BorderThickness="1" BorderBrush="{StaticResource BorderDim}"
                                 Padding="4,2" VerticalContentAlignment="Center"
                                 KeyDown="OnVoiceTestInputKeyDown"
                                 ToolTip="Type the line to speak. Enter to play."/>
                    </DockPanel>
                </Border>
                </StackPanel>

                <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- + Menu button -->
                <Button Grid.Column="0" x:Name="btnPlus"
                        Content="&#xE710;" FontFamily="Segoe MDL2 Assets"
                        FontSize="16" Foreground="{StaticResource PurpleBrush}"
                        Background="Transparent" BorderThickness="0"
                        Padding="6,4" Cursor="Hand" VerticalAlignment="Center"
                        Click="OnPlusClick" ToolTip="Tools">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="ctxPlusMenu" Placement="Top"/>
                    </Button.ContextMenu>
                </Button>

                <Border Grid.Column="1" Background="{StaticResource InputBg}"
                        BorderBrush="{StaticResource InputBorder}" BorderThickness="1"
                        CornerRadius="0" Padding="6,4">
                    <TextBox x:Name="txtInput" Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimary}"
                             CaretBrush="{StaticResource CyanBrush}"
                             FontFamily="Consolas" FontSize="13"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             MaxHeight="80"
                             VerticalScrollBarVisibility="Auto"
                             VerticalAlignment="Stretch"
                             TextChanged="OnInputTextChanged"
                             PreviewKeyDown="OnInputKeyDown"/>
                </Border>

                <Button Grid.Column="2" Content="&#xE724;" FontFamily="Segoe MDL2 Assets"
                        FontSize="16" Foreground="{StaticResource CyanBrush}"
                        Background="Transparent" BorderThickness="0"
                        Padding="10,4" Cursor="Hand" VerticalAlignment="Center"
                        Click="OnSendClick" ToolTip="Send (Enter)"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
