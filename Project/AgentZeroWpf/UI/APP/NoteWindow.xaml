<Window x:Class="AgentZeroWpf.UI.APP.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="clr-namespace:AgentZeroWpf.UI.Components"
        Title="AgentZero — Note"
        Width="1100" Height="700"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#1E1E1E"
        ResizeMode="CanResizeWithGrip"
        Icon="/agentzero.ico"
        StateChanged="OnWindowStateChanged">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg"      Color="#252526"/>
        <SolidColorBrush x:Key="ToolbarBg"    Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#3E3E42"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#3794FF"/>
        <SolidColorBrush x:Key="DangerBrush"  Color="#C42B1C"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#D4D4D4"/>
        <SolidColorBrush x:Key="TextDim"      Color="#858585"/>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#383B3F"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1,0,1,1">
        <Grid x:Name="noteRoot">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="noteTitleBarRow" Height="32"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>   <!-- Content -->
                <RowDefinition x:Name="noteStatusBarRow" Height="24"/>  <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ===== Title Bar ===== -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="OnTitleBarDrag">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1E1E1E" Offset="0"/>
                        <GradientStop Color="#2D2D30" Offset="0.5"/>
                        <GradientStop Color="#1E1E1E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel Margin="8,0">
                    <!-- Window controls -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="&#xE921;" Style="{StaticResource TitleBarButton}"
                                Click="OnMinimizeClick"/>
                        <Button x:Name="MaxRestoreButton" Content="&#xE922;" Style="{StaticResource TitleBarButton}"
                                Click="OnMaximizeClick"/>
                        <Button Content="&#xE8BB;" Style="{StaticResource TitleBarCloseButton}"
                                Click="OnCloseClick"/>
                    </StackPanel>

                    <!-- Title -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock x:Name="txtTitle" Text="NOTE" FontSize="12" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" FontFamily="Consolas"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtPath" Text="" FontSize="10"
                                   Foreground="{StaticResource TextDim}" FontFamily="Consolas"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ===== Content: Tree + Viewer + Clipboard ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" MinWidth="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="300"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="colClipboard" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- File Tree -->
                <components:FileTreePanel x:Name="fileTree" Grid.Column="0"/>

                <!-- Splitter 1 -->
                <GridSplitter Grid.Column="1" Width="3"
                              Background="{StaticResource BorderColor}"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"/>

                <!-- Document Viewer -->
                <components:DocumentViewerPanel x:Name="docViewer" Grid.Column="2"/>

                <!-- Pen Viewer (overlay in same column, shown for .pen files) -->
                <Grid x:Name="penViewerHost" Grid.Column="2" Visibility="Collapsed"
                      Background="#1E1E1E">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource PanelBg}"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1"
                            Padding="8,6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <Button DockPanel.Dock="Left" Content="◀  Prev"
                                        Margin="0,0,6,0" Padding="8,2" Cursor="Hand"
                                        Click="OnPenFramePrev"/>
                                <Button DockPanel.Dock="Left" Content="Next  ▶"
                                        Margin="0,0,12,0" Padding="8,2" Cursor="Hand"
                                        Click="OnPenFrameNext"/>
                                <TextBlock x:Name="txtPenFrameInfo" FontFamily="Consolas"
                                           FontSize="12" Foreground="{StaticResource TextDim}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled" MaxHeight="60">
                                <WrapPanel x:Name="pnlPenFrameButtons"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <ScrollViewer x:Name="svPenFrame" Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#1E1E1E"
                                  SizeChanged="OnPenFrameViewSizeChanged">
                        <Border x:Name="pnlPenFrame" Padding="16"
                                HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
                    </ScrollViewer>
                </Grid>

                <!-- Splitter 2 -->
                <GridSplitter Grid.Column="3" Width="3"
                              Background="{StaticResource BorderColor}"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"
                              Visibility="Collapsed" x:Name="splClipboard"/>

                <!-- Clipboard History -->
                <components:ClipboardHistoryPanel x:Name="clipHistory" Grid.Column="4"
                                                   Visibility="Collapsed"/>
            </Grid>

            <!-- Toast Popup (overlay) -->
            <components:ToastPopup x:Name="toast" Grid.Row="1"
                                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                    Margin="0,0,0,12" Panel.ZIndex="100"/>

            <!-- ===== Status Bar ===== -->
            <Border Grid.Row="2" Padding="8,3">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#2D2D30" Offset="0"/>
                        <GradientStop Color="#252526" Offset="0.5"/>
                        <GradientStop Color="#2D2D30" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <!-- Clipboard toggle -->
                    <Button DockPanel.Dock="Right" x:Name="btnClipToggle"
                            Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                            Foreground="{StaticResource TextDim}" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" Padding="4,1"
                            ToolTip="Toggle Clipboard History" Click="OnToggleClipboard"/>

                    <TextBlock x:Name="txtStatus" Text="Ready"
                               FontSize="10" Foreground="{StaticResource TextDim}"
                               FontFamily="Consolas" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
