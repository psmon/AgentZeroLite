<Window x:Class="AgentZeroWpf.UI.APP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:components="clr-namespace:AgentZeroWpf.UI.Components"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        Title="AgentZero Lite"
        Width="600" Height="500"
        MinWidth="300" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#1E1E1E"
        ResizeMode="CanResizeWithGrip"
        Icon="/agentzero.ico"
        StateChanged="OnWindowStateChanged">

    <Window.Resources>
        <!-- ===== Modern IDE Dark Colors ===== -->
        <Color x:Key="CyberBgDeep">#1E1E1E</Color>
        <Color x:Key="CyberBgPanel">#252526</Color>
        <Color x:Key="CyberBgToolbar">#2D2D30</Color>
        <Color x:Key="CyberBorderDim">#3E3E42</Color>
        <Color x:Key="CyberCyan">#3794FF</Color>
        <Color x:Key="CyberMagenta">#C586C0</Color>
        <Color x:Key="CyberPurple">#4EC9B0</Color>
        <!-- "LITE" accent — fresh spring-mint green -->
        <Color x:Key="CyberMint">#7CFDB0</Color>
        <Color x:Key="CyberYellow">#DCDCAA</Color>
        <Color x:Key="CyberTextPrimary">#D4D4D4</Color>
        <Color x:Key="CyberTextDim">#858585</Color>
        <Color x:Key="SelectionBgColor">#264F78</Color>

        <SolidColorBrush x:Key="PanelBg"      Color="{StaticResource CyberBgPanel}"/>
        <SolidColorBrush x:Key="ToolbarBg"     Color="{StaticResource CyberBgToolbar}"/>
        <SolidColorBrush x:Key="BorderColor"   Color="{StaticResource CyberBorderDim}"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="{StaticResource CyberCyan}"/>
        <SolidColorBrush x:Key="DangerBrush"   Color="{StaticResource CyberMagenta}"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="{StaticResource CyberTextPrimary}"/>
        <SolidColorBrush x:Key="TextDim"       Color="{StaticResource CyberTextDim}"/>
        <SolidColorBrush x:Key="EditorBg"      Color="{StaticResource CyberBgDeep}"/>
        <SolidColorBrush x:Key="InputBg"       Color="#1F1F1F"/>
        <SolidColorBrush x:Key="InputBorder"   Color="#3E3E42"/>
        <SolidColorBrush x:Key="ButtonBg"      Color="#2D2D30"/>
        <SolidColorBrush x:Key="ButtonHover"   Color="#383B3F"/>
        <SolidColorBrush x:Key="CyberCyanBrush"    Color="{StaticResource CyberCyan}"/>
        <SolidColorBrush x:Key="CyberMagentaBrush" Color="{StaticResource CyberMagenta}"/>
        <SolidColorBrush x:Key="CyberPurpleBrush"  Color="{StaticResource CyberPurple}"/>
        <SolidColorBrush x:Key="CyberMintBrush"    Color="{StaticResource CyberMint}"/>
        <SolidColorBrush x:Key="CyberYellowBrush"  Color="{StaticResource CyberYellow}"/>
        <SolidColorBrush x:Key="SelectionBrush"    Color="{StaticResource SelectionBgColor}"/>

        <!-- ===== Flat Button Style (Cyberpunk) ===== -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ButtonHover}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource CyberCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource CyberCyan}" Opacity="0.14"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource CyberCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Accent Button (Neon Cyan) ===== -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#333337" Offset="0"/>
                        <GradientStop Color="#3C3F45" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="{StaticResource CyberCyanBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CyberCyanBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1.5"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource CyberCyan}" Opacity="0.18"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource CyberCyan}" Opacity="0.24"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Small Button (Cyberpunk) ===== -->
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Dark TextBox Style (Cyberpunk) ===== -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource CyberCyanBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SelectionBrush" Value="{StaticResource SelectionBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource CyberCyanBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== Dark CheckBox Style ===== -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ===== Dark DatePicker Style ===== -->
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- ===== ToggleButton for log panel ===== -->
        <Style x:Key="PanelToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar styles moved to App.xaml (global) -->

        <!-- ===== Title Bar Button Style ===== -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ButtonHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource CyberMagenta}" Opacity="0.95"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Sidebar RadioButton Style ===== -->
        <Style x:Key="SidebarRadio" TargetType="RadioButton">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Rectangle x:Name="ActiveBar" Width="3" HorizontalAlignment="Left"
                                       Fill="{StaticResource CyberCyanBrush}" Opacity="0"/>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    Padding="10,0,6,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SideLabel" Text="{TemplateBinding Tag}"
                                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource CyberCyanBrush}"/>
                                <Setter TargetName="ActiveBar" Property="Opacity" Value="1"/>
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource CyberCyan}" Opacity="0.12"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource CyberCyan}" Opacity="0.07"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ContextMenu / MenuItem (Implicit) ===== -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource ButtonHover}"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberCyanBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== CheckBox (Implicit) ===== -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box" Width="14" Height="14"
                                    Background="{StaticResource InputBg}" BorderBrush="{StaticResource InputBorder}"
                                    BorderThickness="1" CornerRadius="0"
                                    VerticalAlignment="Center" Margin="0,0,5,0">
                                <TextBlock x:Name="check" Text="✓"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource CyberCyanBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource CyberCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource CyberCyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ComboBox (Implicit) ===== -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource ButtonHover}"/>
                    <Setter Property="Foreground" Value="{StaticResource CyberCyanBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== ToolTip (Implicit) ===== -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{StaticResource PanelBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>

        <!-- ===== ActivityBar Icon Button ===== -->
        <Style x:Key="ActivityBarIcon" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ButtonHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource CyberCyanBrush}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bd"
                                                      Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                      To="{StaticResource CyberCyan}" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ===== Root Grid: MainBorder ===== -->
    <Grid>
    <!-- ===== Main Container ===== -->
    <Border x:Name="MainBorder" CornerRadius="0" ClipToBounds="True"
            BorderThickness="1,0,1,1"
            Background="{StaticResource EditorBg}">
        <Border.BorderBrush>
            <SolidColorBrush Color="{StaticResource CyberBorderDim}"/>
        </Border.BorderBrush>

        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>     <!-- 0: Title Bar -->
                    <RowDefinition Height="*"/>      <!-- 1: Sidebar + Content -->
                    <RowDefinition Height="Auto"/>   <!-- 2: Status Bar -->
                </Grid.RowDefinitions>

                <!-- ============================================================ -->
                <!-- Row 0: Custom Title Bar                                       -->
                <!-- ============================================================ -->
                <Border Grid.Row="0" MouseLeftButtonDown="OnTitleBarMouseDown"
                        Background="Transparent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <!-- Pencil: vertical gradient bg-deep → bg-toolbar -->
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="{StaticResource CyberBgDeep}" Offset="0"/>
                                        <GradientStop Color="{StaticResource CyberBgToolbar}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Border.Style>
                    <DockPanel>
                        <!-- Window controls (right) -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="&#xE921;" Style="{StaticResource TitleBarButton}"
                                    Click="OnMinimizeClick"/>
                            <Button x:Name="MaxRestoreButton" Content="&#xE922;" Style="{StaticResource TitleBarButton}"
                                    Click="OnMaximizeClick"/>
                            <Button Content="&#xE8BB;" Style="{StaticResource TitleBarCloseButton}"
                                    Click="OnCloseClick"/>
                        </StackPanel>

                        <!-- Title (left) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                            <Polygon Points="8,0 16,8 8,16 0,8" Fill="{StaticResource CyberCyanBrush}"
                                     Opacity="0.8" Margin="0,0,8,0"/>
                            <TextBlock Text="AGENT" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource CyberCyanBrush}"/>
                            <TextBlock Text="ZERO" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource CyberMagentaBrush}" Margin="0,0,0,0"/>
                            <TextBlock Text="LITE" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource CyberMintBrush}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#7CFDB0" BlurRadius="10"
                                                      ShadowDepth="0" Opacity="0.55"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock x:Name="txtVersion" FontFamily="Consolas" FontSize="9"
                                       Foreground="{StaticResource TextDim}" VerticalAlignment="Center"
                                       Margin="6,2,0,0" Opacity="0.6"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Separator line under title (Pencil: transparent → cyan(center) → transparent) -->
                <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="{StaticResource CyberCyan}" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- ============================================================ -->
                <!-- Row 1: ActivityBar + SidePanel + Splitter + Content            -->
                <!-- ============================================================ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48"/>                    <!-- ActivityBar -->
                        <ColumnDefinition Width="200" MinWidth="140"/>    <!-- SidePanel (resizable) -->
                        <ColumnDefinition Width="4"/>                     <!-- topSplitter (Pencil) -->
                        <ColumnDefinition Width="*" MinWidth="300"/>      <!-- Content -->
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>                              <!-- TopRow -->
                        <RowDefinition x:Name="BotSplitterRow" Height="0"/>      <!-- Bot dock splitter -->
                        <RowDefinition x:Name="BotDockRow" Height="0"/>          <!-- BotDockArea (full RightArea width) -->
                    </Grid.RowDefinitions>

                    <!-- topSplitter: resize the side panel (Pencil design element) -->
                    <GridSplitter Grid.Column="2" Grid.Row="0" Width="4"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  ResizeDirection="Columns" ShowsPreview="False"
                                  Background="{StaticResource ToolbarBg}"/>

                    <!-- ===== ActivityBar (Left Icon Bar) — spans all rows ===== -->
                    <Border Grid.Column="0" Grid.RowSpan="3" Background="#1B1B1C"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                        <DockPanel>
                            <!-- Settings at bottom -->
                            <Button x:Name="btnActivitySettings" DockPanel.Dock="Bottom"
                                    Style="{StaticResource ActivityBarIcon}"
                                    Content="&#xE713;" ToolTip="Settings"
                                    Click="OnActivitySettingsClick"/>

                            <!-- Top icons -->
                            <StackPanel Orientation="Vertical" VerticalAlignment="Top" Margin="4,8,0,0">
                                <!-- Bot Icon -->
                                <Button x:Name="btnActivityBot" Style="{StaticResource ActivityBarIcon}"
                                        Content="&#xE99A;" ToolTip="Agent Bot"
                                        Click="OnActivityBotClick"/>

                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ===== SidePanel (Left Sidebar) ===== -->
                    <Border Grid.Column="1" Background="{StaticResource PanelBg}"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                        <DockPanel LastChildFill="true">
                            <!-- Scrollable SidePanel Content -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,8">
                                    <!-- Workspaces Header -->
                                    <StackPanel Orientation="Horizontal" Margin="12,0,0,8">
                                        <Rectangle Width="3" Height="10" Fill="{StaticResource CyberCyanBrush}" Margin="0,0,6,0"/>
                                        <TextBlock Text="WORKSPACES" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource CyberCyanBrush}" FontFamily="Consolas"/>
                                    </StackPanel>

                                    <!-- Workspaces (formerly "DIRECTORIES / CLI Groups" — unified naming) -->
                                    <StackPanel x:Name="pnlCliGroups" Margin="12,4,0,0"/>

                                    <!-- Add Workspace button -->
                                    <Button x:Name="btnAddGroup" Content="+ Add Workspace"
                                            FontSize="11" FontFamily="Consolas" FontWeight="Normal"
                                            Foreground="{StaticResource CyberCyanBrush}"
                                            Background="Transparent"
                                            BorderThickness="0" Padding="12,6,0,6"
                                            Cursor="Hand" HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Click="OnAddGroupClick" ToolTip="Add Workspace"/>

                                    <!-- Separator -->
                                    <Rectangle Height="1" Fill="{StaticResource BorderColor}" Margin="12,8,12,8"/>

                                    <!-- Sessions Header -->
                                    <TextBlock Text="▼ SESSIONS" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource CyberMagentaBrush}" FontFamily="Consolas"
                                               Margin="12,0,0,4"/>

                                    <!-- Session filter -->
                                    <TextBox x:Name="txtSessionFilter"
                                             Style="{StaticResource DarkTextBox}"
                                             FontSize="10" Height="22"
                                             Margin="12,0,12,4"
                                             Tag="Filter sessions..."
                                             TextChanged="OnSessionFilterChanged"/>

                                    <!-- Active Session List -->
                                    <StackPanel x:Name="pnlSessions" Margin="12,0,0,0"/>

                                    <!-- New Session button -->
                                    <Button x:Name="btnNewSession" Content="+ New Session"
                                            FontSize="11" FontFamily="Consolas" FontWeight="Normal"
                                            Foreground="{StaticResource CyberMagentaBrush}"
                                            Background="Transparent"
                                            BorderThickness="0" Padding="12,6,0,6"
                                            Cursor="Hand" HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Click="OnNewSessionClick" ToolTip="Add Terminal Session"/>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- ===== Content Area (TopRow's Content column) ===== -->
                    <Grid Grid.Column="3" Grid.Row="0">

                        <!-- ===== CLI Panel ===== -->
                        <Grid x:Name="CliPanel" Grid.Row="0" Visibility="Visible" Background="{StaticResource EditorBg}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- CLI Header Bar -->
                            <Border Grid.Row="0" Background="{StaticResource PanelBg}"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1"
                                    Padding="6,4">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" x:Name="btnAddConsole" Content="+"
                                            FontSize="16" FontWeight="Bold" Padding="10,2"
                                            Foreground="{StaticResource CyberCyanBrush}"
                                            Style="{StaticResource FlatButton}"
                                            Click="OnAddConsoleClick">
                                        <Button.ContextMenu>
                                            <ContextMenu x:Name="ctxConsoleType"/>
                                        </Button.ContextMenu>
                                    </Button>
                                    <!-- Detach: float the active terminal tab into its own window.
                                         The matching REDOCK control lives inside the floating window
                                         itself (rendered as a strip at the top of the tab content),
                                         not here — putting the "go back" button on the main window
                                         was a mismatch with the user's mental model ("I'm in the
                                         floating window, I want to come back from here"). -->
                                    <Button DockPanel.Dock="Right" x:Name="btnDetachTab"
                                            Content="&#x2922; DETACH"
                                            FontSize="10" FontWeight="Bold" Padding="10,4"
                                            Margin="0,0,4,0"
                                            Foreground="{StaticResource CyberMintBrush}"
                                            Style="{StaticResource FlatButton}"
                                            ToolTip="현재 탭을 새 창으로 분리"
                                            Click="OnDetachActiveTabClick"/>
<!-- Note/Harness buttons moved to BottomPanel tabs -->
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="3" Height="10" Fill="{StaticResource CyberCyanBrush}" Margin="0,0,6,0"
                                                   RadiusX="1" RadiusY="1"/>
                                        <TextBlock Text="CONSOLE" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource CyberCyanBrush}" FontFamily="Consolas"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    </StackPanel>
                                    <Border/>
                                </DockPanel>
                            </Border>

                            <!-- AvalonDock DockingManager -->
                            <avalonDock:DockingManager Grid.Row="1" x:Name="dockManager"
                                                        AllowMixedOrientation="True"
                                                        Background="{StaticResource EditorBg}">
                                <avalonDock:LayoutRoot>
                                    <avalonDock:LayoutPanel Orientation="Horizontal">
                                        <avalonDock:LayoutDocumentPane x:Name="terminalDocPane"/>
                                    </avalonDock:LayoutPanel>
                                </avalonDock:LayoutRoot>
                            </avalonDock:DockingManager>

                        </Grid> <!-- /CliPanel -->

                        <!-- ===== Settings Panel ===== -->
                        <components:SettingsPanel x:Name="SettingsPanel" Visibility="Collapsed"/>

                    </Grid> <!-- /Content Area -->

                    <!-- ===== Bot Dock Splitter (spans SidePanel through Content) ===== -->
                    <GridSplitter x:Name="botDockSplitter" Grid.Row="1"
                                  Grid.Column="1" Grid.ColumnSpan="3"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  ResizeDirection="Rows" ShowsPreview="False"
                                  Background="{StaticResource ToolbarBg}"/>

                    <!-- ===== Embedded BottomPanel (Pencil: spans full RightArea width) ===== -->
                    <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                          x:Name="BotDockArea" Background="{StaticResource EditorBg}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>    <!-- Tab bar -->
                            <RowDefinition Height="*"/>     <!-- Tab content -->
                        </Grid.RowDefinitions>

                        <!-- Tab bar -->
                        <Border Grid.Row="0" Background="{StaticResource PanelBg}"
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                            <DockPanel LastChildFill="True">
                                <!-- Right-side actions -->
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="btnBotUndock"
                                            Content="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                            FontSize="12" Padding="10,0"
                                            Foreground="{StaticResource TextDim}"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" ToolTip="Bot 창 모드로 전환 (Ctrl+Shift+`)"
                                            Click="OnBotUndockClick"/>
                                </StackPanel>

                                <!-- Tabs -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="btnBottomTabBot" Content="AGENT BOT"
                                            Click="OnBottomTabBotClick"
                                            Style="{StaticResource FlatButton}"
                                            Background="{StaticResource EditorBg}"
                                            Foreground="{StaticResource CyberCyanBrush}"
                                            FontSize="10" FontWeight="Bold"
                                            BorderThickness="0,0,0,2" BorderBrush="{StaticResource CyberCyanBrush}"
                                            Padding="14,6" Margin="0"/>
                                    <Button x:Name="btnBottomTabOutput" Content="OUTPUT"
                                            Click="OnBottomTabOutputClick"
                                            Style="{StaticResource FlatButton}"
                                            Background="Transparent"
                                            Foreground="{StaticResource TextDim}"
                                            FontSize="10" FontWeight="Bold"
                                            BorderThickness="0" Padding="14,6" Margin="0"/>
                                    <Button x:Name="btnBottomTabLog" Content="LOG"
                                            Click="OnBottomTabLogClick"
                                            Style="{StaticResource FlatButton}"
                                            Background="Transparent"
                                            Foreground="{StaticResource TextDim}"
                                            FontSize="10" FontWeight="Bold"
                                            BorderThickness="0" Padding="14,6" Margin="0"/>
                                    <Button x:Name="btnBottomTabNote" Content="NOTE"
                                            Click="OnBottomTabNoteClick"
                                            Style="{StaticResource FlatButton}"
                                            Background="Transparent"
                                            Foreground="{StaticResource TextDim}"
                                            FontSize="10" FontWeight="Bold"
                                            BorderThickness="0" Padding="14,6" Margin="0"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Tab content area -->
                        <Grid Grid.Row="1">
                            <ContentControl x:Name="BotDockHost" Visibility="Visible"/>
                            <TextBox x:Name="txtBottomOutput" Visibility="Collapsed"
                                     Background="{StaticResource EditorBg}"
                                     Foreground="{StaticResource TextPrimary}"
                                     BorderThickness="0"
                                     FontFamily="Cascadia Mono" FontSize="11"
                                     IsReadOnly="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Padding="10,6"
                                     CaretBrush="{StaticResource CyberCyanBrush}"
                                     Text="Build / Terminal output will appear here…"/>
                            <TextBox x:Name="txtBottomLog" Visibility="Collapsed"
                                     Background="{StaticResource EditorBg}"
                                     Foreground="{StaticResource TextPrimary}"
                                     BorderThickness="0"
                                     FontFamily="Cascadia Mono" FontSize="11"
                                     IsReadOnly="True" TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     Padding="10,6"
                                     CaretBrush="{StaticResource CyberCyanBrush}"
                                     Text="System log entries will appear here…"/>
                            <ContentControl x:Name="NoteHost" Visibility="Collapsed"/>
                        </Grid>
                    </Grid>

                </Grid> <!-- /Sidebar + Content Row 1 -->

                <!-- ============================================================ -->
                <!-- Row 2: Status Bar (Pencil Design)                             -->
                <!-- ============================================================ -->
                <Border Grid.Row="2" Padding="10,5">
                    <Border.Background>
                        <LinearGradientBrush x:Name="StatusBarGradient" StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{StaticResource CyberBgToolbar}" Offset="0"/>
                            <GradientStop Color="{StaticResource CyberBgPanel}" Offset="0.45"/>
                            <GradientStop Color="{StaticResource CyberBgToolbar}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <DockPanel>
                        <!-- Right side: Bot status + session info -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="statusBotText" Text="⚡ Bot: Inactive"
                                       Foreground="{StaticResource TextDim}" FontSize="10"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                            <Rectangle Width="1" Height="12" Fill="{StaticResource BorderColor}"
                                       Margin="8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="statusSessionText" Text="no session"
                                       Foreground="{StaticResource TextDim}" FontSize="10"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Left side: ready status -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush x:Name="StatusDot" Color="{StaticResource CyberCyan}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock x:Name="statusLabel" Text="READY"
                                       Foreground="{StaticResource CyberCyanBrush}" FontSize="11"
                                       FontFamily="Consolas" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
    </Grid>

</Window>
