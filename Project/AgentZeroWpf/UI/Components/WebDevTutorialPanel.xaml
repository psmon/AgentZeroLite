<UserControl x:Class="AgentZeroWpf.UI.Components.WebDevTutorialPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1B1B1C">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="780" HorizontalAlignment="Left">

            <!-- Hero -->
            <Border Background="#0E1A2A" BorderBrush="#1E3A5F" BorderThickness="1"
                    CornerRadius="6" Padding="16" Margin="0,0,0,18">
                <DockPanel LastChildFill="True">
                    <TextBlock Text="&#x1F310;" FontSize="28" Foreground="#3DA0FF"
                               DockPanel.Dock="Left" VerticalAlignment="Center"
                               Margin="0,0,14,0"/>
                    <StackPanel>
                        <TextBlock Text="WebDev moved to the main menu"
                                   FontSize="15" FontWeight="Bold" Foreground="#E5E5E5"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#9D9D9D"
                                   Margin="0,4,0,0" LineHeight="17">
                            Look at the left activity bar — there's a globe icon right after Agent Bot.
                            Click it for the full WebDev workspace (sample list + full-window canvas).
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- What is WebDev -->
            <TextBlock Text="What is WebDev?" FontSize="13" FontWeight="Bold"
                       Foreground="#E5E5E5" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#CFD0D5"
                       LineHeight="18" Margin="0,0,0,16">
                AgentZero exposes its native capabilities — LLM inference, TTS / STT,
                file system, terminal — through a JavaScript bridge mounted into a
                WebView2 control. Web tools written in plain HTML + JS (and optionally
                compiled WASM) plug in and call those capabilities directly, letting
                you build small AI utilities without touching C#.
            </TextBlock>

            <!-- JS bridge surface -->
            <TextBlock Text="JS bridge surface · window.zero" FontSize="13" FontWeight="Bold"
                       Foreground="#E5E5E5" Margin="0,0,0,6"/>
            <Border Background="#0F0F22" BorderBrush="#2A2A5E" BorderThickness="1"
                    CornerRadius="4" Padding="14,10" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#CFD0D5"
                               Text="await window.zero.version();"/>
                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#CFD0D5"
                               Text="await window.zero.voice.providers();"/>
                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#CFD0D5"
                               Text="await window.zero.voice.speak(&quot;hello&quot;);"/>
                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#CFD0D5"
                               Text="await window.zero.chat.send(&quot;…&quot;);"/>
                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#CFD0D5"
                               Text="await window.zero.chat.stream(&quot;…&quot;, onToken);"/>
                </StackPanel>
            </Border>

            <!-- Build a plugin -->
            <TextBlock Text="Build your own plugin" FontSize="13" FontWeight="Bold"
                       Foreground="#E5E5E5" Margin="0,0,0,6"/>
            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1"
                    CornerRadius="4" Padding="14,12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#CFD0D5"
                               LineHeight="18">
                        <Run Text="A plugin is a folder zipped into a .zip file:" FontWeight="SemiBold"/>
                    </TextBlock>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock FontSize="11" Foreground="#CFD0D5"
                                   Text="&#x1F4C4;  manifest.json  ·  required: id, name, entry  ·  optional: icon, version, description"/>
                        <TextBlock FontSize="11" Foreground="#CFD0D5"
                                   Text="&#x1F310;  index.html (or whatever 'entry' points at)  ·  the UI surface"/>
                        <TextBlock FontSize="11" Foreground="#CFD0D5"
                                   Text="&#x1F4DC;  app.js  ·  glue, calls window.zero.* via /Wasm/common/zero-bridge.js"/>
                        <TextBlock FontSize="11" Foreground="#CFD0D5"
                                   Text="&#x2699;  (optional) plugin.wasm  ·  rust / zig / c heavy compute · M0007"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- manifest example -->
            <TextBlock Text="manifest.json (minimum)" FontSize="11" FontWeight="SemiBold"
                       Foreground="#9D9D9D" Margin="0,0,0,4"/>
            <Border Background="#0F0F22" BorderBrush="#2A2A5E" BorderThickness="1"
                    CornerRadius="4" Padding="14,10" Margin="0,0,0,16">
                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#CFD0D5">
                    <Run Text="{}{"/><LineBreak/>
                    <Run Text="  &quot;id&quot;: &quot;hello-tool&quot;,"/><LineBreak/>
                    <Run Text="  &quot;name&quot;: &quot;Hello Tool&quot;,"/><LineBreak/>
                    <Run Text="  &quot;entry&quot;: &quot;index.html&quot;,"/><LineBreak/>
                    <Run Text="  &quot;version&quot;: &quot;0.1.0&quot;,"/><LineBreak/>
                    <Run Text="  &quot;description&quot;: &quot;chat helper that does X&quot;"/><LineBreak/>
                    <Run Text="}"/>
                </TextBlock>
            </Border>

            <!-- Install -->
            <TextBlock Text="Install a plugin" FontSize="13" FontWeight="Bold"
                       Foreground="#E5E5E5" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#CFD0D5"
                       LineHeight="18" Margin="0,0,0,8">
                <Run Text="① Open WebDev from the activity bar  ·  "/>
                <Run Text="② Click '+ Install Plugin' at the bottom of the sample list  ·  "/>
                <Run Text="③ Pick a .zip — it extracts into "/>
                <Run FontFamily="Consolas" Foreground="#7ED9A0" Text="%LOCALAPPDATA%/AgentZeroLite/Wasm/plugins/{id}/"/>
                <Run Text=" and the menu refreshes automatically."/>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</UserControl>
