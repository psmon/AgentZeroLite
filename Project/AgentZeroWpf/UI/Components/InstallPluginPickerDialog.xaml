<Window x:Class="AgentZeroWpf.UI.Components.InstallPluginPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Install WebDev Plugin"
        Width="520" Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#1B1B1C">
    <Window.Resources>
        <Style x:Key="ChoiceButton" TargetType="Button">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0A84FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Install WebDev Plugin"
                       FontSize="16" FontWeight="Bold" Foreground="#E5E5E5"/>
            <TextBlock Text="Pick how the plugin gets in. Both end up at %LOCALAPPDATA%\AgentZeroLite\Wasm\plugins\{id}\."
                       FontSize="11" Foreground="#9D9D9D" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Mode picker (default view) -->
        <StackPanel x:Name="ModePicker" Grid.Row="1">
            <Button Style="{StaticResource ChoiceButton}" Margin="0,0,0,10" Click="OnPickZip">
                <StackPanel>
                    <TextBlock Text="📦  From .zip…" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="Local file. Pick a zip with manifest.json at the root or in a single top-level folder."
                               FontSize="10" Foreground="#9D9D9D" TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ChoiceButton}" Click="OnPickGit">
                <StackPanel>
                    <TextBlock Text="🌐  From Git URL…" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="Public GitHub folder URL like https://github.com/owner/repo/tree/main/plugins/my-plugin. No git CLI required."
                               FontSize="10" Foreground="#9D9D9D" TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Git URL input (shown after picking Git) -->
        <StackPanel x:Name="GitInput" Grid.Row="1" Visibility="Collapsed">
            <TextBlock Text="Git folder URL" FontSize="11" FontWeight="SemiBold"
                       Foreground="#9D9D9D" Margin="0,0,0,6"/>
            <TextBox x:Name="tbGitUrl"
                     Background="#0F0F22" Foreground="#E5E5E5"
                     CaretBrush="#3DA0FF" BorderBrush="#2A2A5E"
                     BorderThickness="1" Padding="8,6"
                     FontFamily="Consolas" FontSize="11"
                     Text="https://github.com/psmon/AgentZeroLite/tree/main/Project/Plugins/voice-note"/>
            <TextBlock Margin="0,8,0,0" FontSize="10" Foreground="#6E6E73" TextWrapping="Wrap">
                The installer fetches manifest.json from the raw URL first, validates it,
                then downloads every file in the folder via the GitHub Trees API.
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="OnCancel"/>
            <Button x:Name="btnConfirmGit" Content="Install" Style="{StaticResource PrimaryButton}"
                    Visibility="Collapsed" Click="OnConfirmGit"/>
        </StackPanel>
    </Grid>
</Window>
