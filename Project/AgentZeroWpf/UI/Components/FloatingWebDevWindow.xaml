<Window x:Class="AgentZeroWpf.UI.Components.FloatingWebDevWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="WebDev Floating"
        Width="720" Height="480"
        MinWidth="320" MinHeight="220"
        WindowStyle="None"
        Background="#0A0A14"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        WindowStartupLocation="Manual">

    <!-- WindowChrome: custom-titlebar + native drag/resize + native window
         buttons hidden, all WITHOUT AllowsTransparency (HwndHost-based
         WebView2 cannot render in layered windows). Caption height matches
         the visible titlebar so drag from the top strip works natively. -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="24"
            ResizeBorderThickness="6"
            CornerRadius="0"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9D9D9D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="2">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3F"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChromeBtnPrimary" TargetType="Button" BasedOn="{StaticResource ChromeBtn}">
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="ChromeMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu x:Name="floatingContextMenu" Background="#1F1F22"
                     BorderBrush="#3F3F46" BorderThickness="1">
            <MenuItem x:Name="miPin" Header="📌  Pin (Always on top)"
                      IsCheckable="True"
                      Style="{StaticResource ChromeMenuItem}"
                      Click="OnPinToggle"/>
            <MenuItem x:Name="miChrome"
                      Header="▭  Title bar"
                      IsCheckable="True" IsChecked="True"
                      Style="{StaticResource ChromeMenuItem}"
                      Click="OnChromeToggle"
                      ToolTip="Hide titlebar — recovery via the 8-px blue strip at the very top of the window (left-click drag = move, single click = restore titlebar, right-click = this menu)."/>
            <Separator Background="#3F3F46"/>
            <MenuItem Header="Transparency" Style="{StaticResource ChromeMenuItem}"
                      StaysOpenOnClick="True">
                <MenuItem.Icon>
                    <TextBlock Text="🌫" Foreground="#9D9D9D"/>
                </MenuItem.Icon>
                <MenuItem StaysOpenOnClick="True"
                          Style="{StaticResource ChromeMenuItem}">
                    <MenuItem.Header>
                        <StackPanel Width="220">
                            <DockPanel LastChildFill="False" Margin="0,0,0,4">
                                <TextBlock Text="Opacity"
                                           Foreground="#E5E5E5" FontSize="11"
                                           DockPanel.Dock="Left"/>
                                <TextBlock x:Name="lblOpacityPct" Text="100%"
                                           Foreground="#3DA0FF" FontSize="11"
                                           FontWeight="Bold"
                                           DockPanel.Dock="Right"/>
                            </DockPanel>
                            <Slider x:Name="sldOpacity" Minimum="0.5" Maximum="1.0"
                                    Value="1.0" TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    Foreground="#3DA0FF"/>
                            <TextBlock Text="50% ────────── 100%"
                                       Foreground="#5F6F8E" FontSize="9"
                                       Margin="0,2,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
            </MenuItem>
            <Separator Background="#3F3F46"/>
            <MenuItem Header="↻  Reload" Style="{StaticResource ChromeMenuItem}"
                      Click="OnReload"/>
            <MenuItem Header="⚙  DevTools" Style="{StaticResource ChromeMenuItem}"
                      Click="OnDevTools"/>
            <Separator Background="#3F3F46"/>
            <MenuItem Header="⤡  Dock back to main window"
                      Foreground="#FFFFFF" Background="#0A84FF"
                      FontWeight="Bold"
                      Style="{StaticResource ChromeMenuItem}"
                      Click="OnDockBack"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Border BorderBrush="#3F3F46" BorderThickness="1" Background="#0A0A14">
        <Grid>
            <Grid.RowDefinitions>
                <!-- chrome handle gets its own row above webHost so the
                     WebView2 HwndHost airspace can't cover it. Height
                     flips between 0 (chrome ON) and 8 (chrome OFF). -->
                <RowDefinition x:Name="rowHandle" Height="0"/>
                <RowDefinition x:Name="rowTitle" Height="24"/>   <!-- compact titlebar -->
                <RowDefinition Height="*"/>                      <!-- WebView2 host -->
                <RowDefinition x:Name="rowFooter" Height="20"/>  <!-- compact footer -->
            </Grid.RowDefinitions>

            <!-- ===== Chrome handle — visible only when chrome OFF.
                 8-px tall accent strip on its own row (not z-ordered
                 over webHost) so it survives WebView2's native HWND
                 airspace. Left-click+drag = move, single click =
                 restore titlebar, right-click = settings menu. ===== -->
            <Border x:Name="chromeHandle" Grid.Row="0"
                    Background="#3DA0FF"
                    BorderBrush="#1F2A4A" BorderThickness="0,0,0,1"
                    Visibility="Collapsed"
                    Cursor="SizeAll"
                    ToolTip="Drag to move  ·  Click to restore titlebar  ·  Right-click for settings"
                    MouseLeftButtonDown="OnChromeHandleLeftDown"
                    MouseRightButtonUp="OnChromeHandleRightClick"/>

            <!-- ===== Compact titlebar (always visible when chrome ON).
                 Drag = native via WindowChrome CaptionHeight=24. Buttons
                 opt out of the drag region with IsHitTestVisibleInChrome
                 =True. ===== -->
            <Border x:Name="titleBar" Grid.Row="1" Background="#1F2A4A">
                <DockPanel LastChildFill="False" Margin="8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                DockPanel.Dock="Left">
                        <Ellipse Width="6" Height="6" Fill="#7ED9A0"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblTitle" Text="WebDev — sample"
                                   Foreground="#E5E5E5" FontSize="10"
                                   FontWeight="Bold" Margin="6,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                DockPanel.Dock="Right">
                        <Button x:Name="btnPinChrome" Content="📌"
                                ToolTip="Pin (always on top)"
                                Style="{StaticResource ChromeBtnPrimary}"
                                Click="OnPinToggle"/>
                        <Button x:Name="btnDockBackChrome" Content="⤡"
                                ToolTip="Dock back to main window"
                                Style="{StaticResource ChromeBtn}"
                                Click="OnDockBack"
                                Margin="3,0,0,0"/>
                        <Button Content="✕" FontSize="11"
                                Style="{StaticResource ChromeBtn}"
                                Click="OnDockBack"
                                Margin="2,0,0,0"
                                ToolTip="Close = dock back"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ===== Body (WebView2 reparenting target) ===== -->
            <Grid Grid.Row="2" x:Name="webHost" Background="#0E1422"
                  ClipToBounds="True"/>

            <!-- ===== Compact footer hint ===== -->
            <Border x:Name="footerBar" Grid.Row="3" Background="#1F1F22">
                <DockPanel LastChildFill="False" Margin="8,0">
                    <TextBlock Text="Right-click titlebar for settings"
                               Foreground="#5F6F8E" FontSize="9"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Left"/>
                    <TextBlock x:Name="lblFooterStatus"
                               Foreground="#5F6F8E" FontSize="9"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Right"
                               Text="opacity 100% · pin off"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
