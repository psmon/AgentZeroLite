<Window x:Class="AgentZeroWpf.UI.Components.ModelDownloadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download Model"
        Width="560" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#1B1B1C">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#7A2A2A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- title -->
            <RowDefinition Height="Auto"/>     <!-- description -->
            <RowDefinition Height="Auto"/>     <!-- caption / detail -->
            <RowDefinition Height="Auto"/>     <!-- progress bar -->
            <RowDefinition Height="Auto"/>     <!-- options (Start fresh) -->
            <RowDefinition Height="*"/>        <!-- spacer -->
            <RowDefinition Height="Auto"/>     <!-- buttons -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="tbDialogTitle" Text="Download Model"
                   FontSize="16" FontWeight="Bold" Foreground="#E5E5E5"/>
        <TextBlock Grid.Row="1" x:Name="tbDialogDescription"
                   Text="First run downloads the model. Subsequent runs use the local cache."
                   FontSize="11" Foreground="#9D9D9D" TextWrapping="Wrap" Margin="0,4,0,12"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,4">
            <TextBlock x:Name="tbCaption" Text="Waiting to start…"
                       FontSize="13" Foreground="#E5E5E5"/>
            <!-- TextBox (read-only) instead of TextBlock so long error messages
                 (stderr tracebacks) can be selected + copied without leaving
                 the dialog. AcceptsReturn + scrollbar handle multi-line. -->
            <TextBox x:Name="tbDetail" Text=""
                     FontSize="10" Foreground="#9D9D9D" FontFamily="Consolas"
                     Background="Transparent" BorderThickness="0"
                     IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                     MaxHeight="80" VerticalScrollBarVisibility="Auto"
                     Margin="0,2,0,0"/>
        </StackPanel>

        <ProgressBar Grid.Row="3" x:Name="pb" Height="14" Margin="0,8,0,12"
                     Background="#0F0F22" BorderBrush="#2A2A5E" Foreground="#0A84FF"
                     Minimum="0" Maximum="100" Value="0" IsIndeterminate="True"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,4,0,0">
            <CheckBox x:Name="chkStartFresh" Content="Start fresh (delete cache before downloading)"
                      Foreground="#C8C8D8" FontSize="11"
                      ToolTip="If a previous cancelled download left locked partial files, tick this to wipe the cache directory before retrying."/>
            <TextBlock x:Name="tbCachePath" Margin="10,1,0,0" FontSize="10"
                       Foreground="#6E6E73" FontFamily="Consolas" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnStart" Content="Start download" Style="{StaticResource PrimaryButton}"
                    Click="OnStart"/>
            <Button x:Name="btnCancel" Content="Cancel" Style="{StaticResource GhostButton}"
                    Margin="8,0,0,0" Click="OnCancel" IsEnabled="False"/>
            <Button x:Name="btnClose" Content="Close" Style="{StaticResource GhostButton}"
                    Margin="8,0,0,0" Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
