<UserControl x:Class="AgentZeroWpf.UI.Components.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:AgentZeroWpf.UI.Components"
             Background="#08081A">

    <UserControl.Resources>
        <!-- Dark TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="CaretBrush" Value="#00E5FF"/>
            <Setter Property="BorderBrush" Value="#2A2A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>

        <!-- Dark ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#2A2A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn" Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" Background="Transparent">
                                                    <TextBlock Text="▾" Foreground="#556677"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="10"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,3,24,3" VerticalAlignment="Center"
                                              HorizontalAlignment="Left" IsHitTestVisible="False"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                        MaxHeight="200" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark editable ComboBox — used for free-text model IDs (cbExtModel).
             Renders an editable TextBox in the closed state so the typed value
             stays visible, while keeping the same dark popup as DarkComboBox. -->
        <Style x:Key="DarkComboBoxEditable" TargetType="ComboBox">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#2A2A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.ColumnSpan="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>
                            <TextBox x:Name="PART_EditableTextBox" Grid.Column="0"
                                     Margin="4,0,0,0" Padding="{TemplateBinding Padding}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{TemplateBinding Foreground}"
                                     CaretBrush="#00E5FF"
                                     VerticalContentAlignment="Center"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}">
                                            <TextBlock Text="&#x25BE;" Foreground="#556677"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontSize="10"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                        MaxHeight="200" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00E5FF"/>
                                <Setter Property="Foreground" Value="#0B0B0B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00B8D4"/>
                                <Setter Property="Foreground" Value="#0B0B0B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark PasswordBox -->
        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="CaretBrush" Value="#00E5FF"/>
            <Setter Property="BorderBrush" Value="#2A2A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>

        <!-- Dark Button -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00E5FF"/>
            <Setter Property="Background" Value="#14143A"/>
            <Setter Property="BorderBrush" Value="#2A2A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E5E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A0A2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ListViewItem — full-inversion selection so the picked row is unmistakable.
             Default WPF ListViewItem uses SystemColors.HighlightBrush which barely contrasts
             against #1E1E1E on dark themes. We swap to the cyan accent + dark text. -->
        <Style x:Key="DarkListViewItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <GridViewRowPresenter
                                Columns="{TemplateBinding GridView.ColumnCollection}"
                                Content="{TemplateBinding Content}"
                                TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2F45"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00E5FF"/>
                                <Setter Property="Foreground" Value="#0B0B0B"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#0099AA"/>
                                <Setter Property="Foreground" Value="#0B0B0B"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark GridView column header — keeps the table header dark too -->
        <Style x:Key="DarkGridViewColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#9FB7CC"/>
            <Setter Property="BorderBrush" Value="#2A2A5E"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab item style -->
        <Style x:Key="SettingsTabItem" TargetType="TabItem">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#556677"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Cursor="Hand">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#00FFF0"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00FFF0"/>
                                <Setter TargetName="Bd" Property="Background" Value="#0D0D1A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#12122A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="True">
            <Button x:Name="btnSettingsClose" DockPanel.Dock="Right"
                    Content="&#x2715;  CLOSE" Padding="14,5"
                    Background="#2A1320" BorderThickness="1"
                    BorderBrush="#5A2540"
                    Foreground="#FFB0C8" FontSize="11" FontWeight="Bold"
                    FontFamily="Consolas"
                    Cursor="Hand" ToolTip="닫기 (일반 화면으로)"
                    Click="OnSettingsCloseClick">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="2"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#C42B1C"/>
                                            <Setter TargetName="bd" Property="BorderBrush" Value="#E81123"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#7A1810"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Rectangle Width="3" Height="14" Fill="#00E5FF" RadiusX="1" RadiusY="1" Margin="0,0,8,0"/>
                <TextBlock Text="SETTINGS" FontSize="14" FontWeight="Bold"
                           Foreground="#00E5FF" FontFamily="Consolas"/>
            </StackPanel>
        </DockPanel>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    Padding="0">
            <!-- CLI Definitions Tab -->
            <TabItem Header="&#x2699; CLI Definitions" Style="{StaticResource SettingsTabItem}">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="2"
                            Background="#1E1E1E">
                        <ListView x:Name="lvCliDefs" Background="Transparent" BorderThickness="0"
                                  Foreground="#D4D4D4" FontFamily="Consolas" FontSize="12"
                                  ItemContainerStyle="{StaticResource DarkListViewItem}"
                                  SelectionChanged="OnCliDefSelectionChanged">
                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource DarkGridViewColumnHeader}">
                                    <GridViewColumn Header="Name" Width="100"
                                                    DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="ExePath" Width="200"
                                                    DisplayMemberBinding="{Binding ExePath}"/>
                                    <GridViewColumn Header="Args" Width="100"
                                                    DisplayMemberBinding="{Binding Arguments}"/>
                                    <GridViewColumn Header="BuiltIn" Width="60"
                                                    DisplayMemberBinding="{Binding IsBuiltIn}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Left">
                        <Button Content="+ ADD" Padding="12,6" Margin="0,0,6,0"
                                FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                Foreground="#00E5FF" Background="#2D2D30"
                                BorderBrush="#3E3E42" BorderThickness="1"
                                Cursor="Hand" Click="OnAddCliDef"/>
                        <Button x:Name="btnEditCliDef" Content="EDIT" Padding="12,6" Margin="0,0,6,0"
                                FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                Foreground="#D4D4D4" Background="#2D2D30"
                                BorderBrush="#3E3E42" BorderThickness="1"
                                Cursor="Hand" Click="OnEditCliDef" IsEnabled="False"/>
                        <Button x:Name="btnDelCliDef" Content="DELETE" Padding="12,6"
                                FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                Foreground="#D13438" Background="#2D2D30"
                                BorderBrush="#3E3E42" BorderThickness="1"
                                Cursor="Hand" Click="OnDeleteCliDef" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- LLM Tab — Local (Gemma) + External (Webnori/OpenAI/LMStudio/Ollama) -->
            <TabItem Header="&#x1F916; LLM" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">

                        <!-- ACTIVE BACKEND SELECTOR (shared) — decides which backend
                             TestBot, AgentBot, and AIMODE all flow through. -->
                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Rectangle Width="3" Height="10" Fill="#FFB800" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="ACTIVE BACKEND" FontSize="11" FontWeight="Bold"
                                               Foreground="#FFB800" FontFamily="Consolas"/>
                                    <TextBlock x:Name="tbActiveBackendStatus" FontFamily="Consolas" FontSize="10"
                                               Foreground="#7C7C8C" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="rbBackendLocal" GroupName="LlmBackend"
                                                 Content="Local (on-device Gemma 4 / Nemotron)"
                                                 Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                 VerticalAlignment="Center" Margin="0,0,16,0"
                                                 Checked="OnActiveBackendChanged"/>
                                    <RadioButton x:Name="rbBackendExternal" GroupName="LlmBackend"
                                                 Content="External (Webnori / OpenAI / LMStudio / Ollama)"
                                                 Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                 VerticalAlignment="Center"
                                                 Checked="OnActiveBackendChanged"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="9"
                                           Foreground="#556677" Margin="0,6,0,0"
                                           Text="Local needs a downloaded GGUF + Load. External just needs a provider/model (Webnori is preconfigured for contributors). AIMODE toolchain is Gemma-4-shaped — non-Gemma external models will likely fail JSON envelope parsing."/>
                            </StackPanel>
                        </Border>

                        <!-- Per-backend config sub-tabs -->
                        <TabControl x:Name="tcLlmBackend" Background="Transparent" BorderThickness="0"
                                    Margin="0,0,0,8" SelectionChanged="OnLlmBackendSubTabChanged">
                            <TabItem Header="Local (Gemma)" Style="{StaticResource SettingsTabItem}">
                                <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Margin="0,8,0,0">

                        <!-- Local backend status — base LLM tests passed for both,
                             but AIMODE toolchain (GBNF + 5-tool envelope) is Gemma-only. -->
                        <Border Background="#0E1F2A" BorderBrush="#00E5FF" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#x2139;" FontSize="14" Foreground="#00E5FF"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="온디바이스 LLM 상태" FontSize="13" FontWeight="Bold"
                                               Foreground="#00E5FF" FontFamily="Consolas"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                           Foreground="#C8D8E0" LineHeight="16">
                                    <Run FontWeight="Bold" Foreground="#00FFAA">기본 LLM 테스트 완료</Run><Run> — Gemma 4 / Nemotron Nano 둘 다 Load + 멀티턴 채팅 + 함수콜 단위로는 정상 동작.</Run>
                                    <LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#00FFAA">AIMODE 툴체인은 Gemma 전용</Run><Run> — 5-tool JSON envelope + GBNF 그래마가 Gemma 4 기준으로 표준화됨. </Run><Run FontWeight="Bold" Foreground="#FFB800">Nemotron 등 Llama-3.x 계열은 AIMODE 비호환</Run><Run> (TestBot 일반 채팅은 OK).</Run>
                                    <LineBreak/>
                                    <Run Foreground="#888899">CPU 백엔드 안정. Vulkan 백엔드는 일부 GPU/드라이버 조합에서 native crash가 보고됨 — Docs/gemma4-gpu-load-failures.md 참고.</Run>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Model Status -->
                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Rectangle Width="3" Height="10" Fill="#00E5FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="MODEL" FontSize="11" FontWeight="Bold"
                                               Foreground="#00E5FF" FontFamily="Consolas"/>
                                    <TextBlock x:Name="tbLlmModelState" Text="[Missing]" FontSize="10"
                                               Foreground="#FF2D95" FontFamily="Consolas"
                                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ComboBox x:Name="cbLlmModel" Style="{StaticResource DarkComboBox}"
                                          Margin="0,0,0,6"
                                          SelectionChanged="OnLlmModelSelectionChanged"/>
                                <TextBox x:Name="tbLlmModelPath" Style="{StaticResource DarkTextBox}"
                                         IsReadOnly="True" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar x:Name="pbLlmDownload" Grid.Column="0" Height="14"
                                                 Minimum="0" Maximum="100" Value="0"
                                                 Foreground="#00E5FF" Background="#12122A"
                                                 BorderBrush="#2A2A5E"/>
                                    <Button x:Name="btnLlmDownload" Grid.Column="1"
                                            Content="Download" Padding="12,5" Margin="8,0,0,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmDownloadClick"/>
                                </Grid>
                                <TextBlock x:Name="tbLlmDownloadStatus" FontFamily="Consolas" FontSize="10"
                                           Foreground="#556677" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Runtime Options -->
                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Rectangle Width="3" Height="10" Fill="#8B00FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="RUNTIME OPTIONS" FontSize="11" FontWeight="Bold"
                                               Foreground="#8B00FF" FontFamily="Consolas"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Backend" Grid.Row="0" Grid.Column="0"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                    <ComboBox x:Name="cbLlmBackend" Grid.Row="0" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}" Margin="0,3,12,3">
                                        <ComboBoxItem Content="Cpu"/>
                                        <ComboBoxItem Content="Vulkan"/>
                                    </ComboBox>

                                    <TextBlock Text="GPU Layers" Grid.Row="0" Grid.Column="2"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                    <TextBox x:Name="tbLlmGpuLayers" Grid.Row="0" Grid.Column="3"
                                             Style="{StaticResource DarkTextBox}" Margin="0,3,0,3"/>

                                    <TextBlock Text="GPU Device" Grid.Row="2" Grid.Column="2"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                    <ComboBox x:Name="cbLlmGpuDevice" Grid.Row="2" Grid.Column="3"
                                              Style="{StaticResource DarkComboBox}" Margin="0,3,0,3"/>

                                    <TextBlock Text="Context Size" Grid.Row="1" Grid.Column="0"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                    <TextBox x:Name="tbLlmContextSize" Grid.Row="1" Grid.Column="1"
                                             Style="{StaticResource DarkTextBox}" Margin="0,3,12,3"/>

                                    <TextBlock Text="Chat MaxTok" Grid.Row="1" Grid.Column="2"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"
                                               ToolTip="TestBot free-form answer length cap. Not used by AIMODE."/>
                                    <TextBox x:Name="tbLlmMaxTokens" Grid.Row="1" Grid.Column="3"
                                             Style="{StaticResource DarkTextBox}" Margin="0,3,0,3"/>

                                    <TextBlock Text="Temperature" Grid.Row="2" Grid.Column="0"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                    <TextBox x:Name="tbLlmTemperature" Grid.Row="2" Grid.Column="1"
                                             Style="{StaticResource DarkTextBox}" Margin="0,3,12,3"/>

                                    <TextBlock Text="AIMODE MaxTok" Grid.Row="3" Grid.Column="0"
                                               Foreground="#9D87FF" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"
                                               ToolTip="Per-turn token budget for the AIMODE tool-call loop. Default 2048. Lower = faster fail on grammar trailing-whitespace stall but risks `done` JSON truncation."/>
                                    <TextBox x:Name="tbLlmAgentLoopMaxTokens" Grid.Row="3" Grid.Column="1"
                                             Style="{StaticResource DarkTextBox}" Margin="0,3,12,3"/>
                                    <TextBlock Text="(per AIMODE turn)" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2"
                                               Foreground="#7C7C8C" FontFamily="Consolas" FontSize="9"
                                               VerticalAlignment="Center" Margin="0,3,0,3"/>
                                </Grid>

                                <!-- KV Cache & Attention (experimental, user-tunable) -->
                                <Border BorderBrush="#2A2A5E" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="KV CACHE / ATTENTION (experimental)"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="#FF2D95" FontFamily="Consolas"
                                                   Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Flash Attention" Grid.Row="0" Grid.Column="0"
                                                       Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,3,6,3"/>
                                            <CheckBox x:Name="chkLlmFlashAttn" Grid.Row="0" Grid.Column="1"
                                                      Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                      VerticalAlignment="Center" Margin="0,3,12,3"
                                                      Content="enable"/>

                                            <TextBlock Text="No KQV Offload" Grid.Row="0" Grid.Column="2"
                                                       Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,3,6,3"/>
                                            <CheckBox x:Name="chkLlmNoKqvOffload" Grid.Row="0" Grid.Column="3"
                                                      Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                      VerticalAlignment="Center" Margin="0,3,0,3"
                                                      Content="KV stays on CPU RAM"/>

                                            <TextBlock Text="KV Type K" Grid.Row="1" Grid.Column="0"
                                                       Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,3,6,3"/>
                                            <ComboBox x:Name="cbLlmKvTypeK" Grid.Row="1" Grid.Column="1"
                                                      Style="{StaticResource DarkComboBox}" Margin="0,3,12,3">
                                                <ComboBoxItem Content="F16 (default)"/>
                                                <ComboBoxItem Content="F32"/>
                                                <ComboBoxItem Content="Q8_0"/>
                                                <ComboBoxItem Content="Q4_0"/>
                                            </ComboBox>

                                            <TextBlock Text="KV Type V" Grid.Row="1" Grid.Column="2"
                                                       Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,3,6,3"/>
                                            <ComboBox x:Name="cbLlmKvTypeV" Grid.Row="1" Grid.Column="3"
                                                      Style="{StaticResource DarkComboBox}" Margin="0,3,0,3">
                                                <ComboBoxItem Content="F16 (default)"/>
                                                <ComboBoxItem Content="F32"/>
                                                <ComboBoxItem Content="Q8_0"/>
                                                <ComboBoxItem Content="Q4_0"/>
                                            </ComboBox>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Use mmap" Foreground="#C8C8D8"
                                                       FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <CheckBox x:Name="chkLlmUseMmap" Foreground="#C8C8D8"
                                                      FontFamily="Consolas" FontSize="10"
                                                      VerticalAlignment="Center"
                                                      Content="keep model pages resident (faster reload, ~5GB RSS)"/>
                                        </StackPanel>
                                        <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="9"
                                                   Foreground="#556677" Margin="0,6,0,0"
                                                   Text="KV constraints: (1) V-cache quantization (Q8_0/Q4_0 V) requires Flash Attention ON — if you pick Q8_0 for V without FA, llama.cpp will refuse to allocate the context. (2) K can always be quantized independently (Q8_0 K + F16 V works with or without FA). (3) mmap OFF frees up to 5GB RAM after GPU upload. Changes apply on next Load."/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="btnLlmAutoRecommend" Content="&#x1F3AF; Auto Recommend"
                                            Padding="12,5" Margin="0,0,6,0"
                                            Style="{StaticResource DarkButton}"
                                            ToolTip="Compute safe options based on current GPU/RAM state. Applies to fields only — click Save Options + Load to use."
                                            Click="OnLlmAutoRecommendClick"/>
                                    <Button x:Name="btnLlmSaveOptions" Content="Save Options"
                                            Padding="12,5" Margin="0,0,6,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmSaveOptionsClick"/>
                                    <Button x:Name="btnLlmLoad" Content="Load Model"
                                            Padding="12,5" Margin="0,0,6,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmLoadClick"/>
                                    <Button x:Name="btnLlmUnload" Content="Unload"
                                            Padding="12,5" Margin="0,0,6,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmUnloadClick" IsEnabled="False"/>
                                    <TextBlock x:Name="tbLlmRuntimeState" Text="State: Unloaded"
                                               FontFamily="Consolas" FontSize="10"
                                               Foreground="#556677" VerticalAlignment="Center"
                                               Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="External" Style="{StaticResource SettingsTabItem}">
                                <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Margin="0,8,0,0">

                                        <!-- Provider selection -->
                                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Rectangle Width="3" Height="10" Fill="#00E5FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                                    <TextBlock Text="PROVIDER" FontSize="11" FontWeight="Bold"
                                                               Foreground="#00E5FF" FontFamily="Consolas"/>
                                                </StackPanel>
                                                <ComboBox x:Name="cbExtProvider" Style="{StaticResource DarkComboBox}"
                                                          Margin="0,0,0,6"
                                                          SelectionChanged="OnExtProviderChanged">
                                                    <ComboBoxItem Content="Webnori a1 — workhorse (Gemma 4 / GPT-OSS / embeddings · test key bundled)"/>
                                                    <ComboBoxItem Content="Webnori a2 — experimental (Qwen3.6-27B / Nemotron-3-Nano-4B · same test key)"/>
                                                    <ComboBoxItem Content="OpenAI (api.openai.com — requires key)"/>
                                                    <ComboBoxItem Content="LMStudio (your own LM Studio server)"/>
                                                    <ComboBoxItem Content="Ollama (localhost:11434)"/>
                                                </ComboBox>
                                                <TextBlock x:Name="tbExtProviderHint" TextWrapping="Wrap"
                                                           FontFamily="Consolas" FontSize="9"
                                                           Foreground="#7C7C8C" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Endpoint config (per-provider; Webnori is read-only) -->
                                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Rectangle Width="3" Height="10" Fill="#8B00FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                                    <TextBlock Text="ENDPOINT" FontSize="11" FontWeight="Bold"
                                                               Foreground="#8B00FF" FontFamily="Consolas"/>
                                                </StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="Base URL" Grid.Row="0" Grid.Column="0"
                                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                                    <TextBox x:Name="tbExtBaseUrl" Grid.Row="0" Grid.Column="1"
                                                             Style="{StaticResource DarkTextBox}" Margin="0,3,0,3"/>

                                                    <TextBlock Text="API Key" Grid.Row="1" Grid.Column="0"
                                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                                    <TextBox x:Name="tbExtApiKey" Grid.Row="1" Grid.Column="1"
                                                             Style="{StaticResource DarkTextBox}" Margin="0,3,0,3"/>
                                                </Grid>
                                                <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="9"
                                                           Foreground="#556677" Margin="0,6,0,0"
                                                           Text="OpenAI: leave Base URL empty to use api.openai.com. LMStudio: typical http://localhost:1234. Ollama: empty defaults to localhost:11434. Webnori: read-only."/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Model + token cap -->
                                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Rectangle Width="3" Height="10" Fill="#00FFAA" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                                    <TextBlock Text="MODEL" FontSize="11" FontWeight="Bold"
                                                               Foreground="#00FFAA" FontFamily="Consolas"/>
                                                </StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- IsEditable lets users type a model id that's not in the
                                                         provider's /v1/models list (common for niche LM Studio
                                                         loads). DarkComboBoxEditable provides the dark template
                                                         with a real PART_EditableTextBox so the typed value stays
                                                         visible. -->
                                                    <ComboBox x:Name="cbExtModel" Grid.Column="0"
                                                              Style="{StaticResource DarkComboBoxEditable}"
                                                              SelectionChanged="OnExtModelChanged"/>
                                                    <Button x:Name="btnExtRefreshModels" Grid.Column="1"
                                                            Content="Refresh" Padding="12,5" Margin="8,0,0,0"
                                                            Style="{StaticResource DarkButton}"
                                                            Click="OnExtRefreshModelsClick"/>
                                                </Grid>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="MaxTokens" Grid.Column="0"
                                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                                               ToolTip="Per-request token cap. The only knob — every other tuning happens server-side."/>
                                                    <TextBox x:Name="tbExtMaxTokens" Grid.Column="1"
                                                             Style="{StaticResource DarkTextBox}"/>
                                                    <TextBlock Text="(per request)" Grid.Column="2"
                                                               Foreground="#7C7C8C" FontFamily="Consolas" FontSize="9"
                                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Save / Test -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button x:Name="btnExtSave" Content="Save Options"
                                                    Padding="12,5" Margin="0,0,6,0"
                                                    Style="{StaticResource DarkButton}"
                                                    Click="OnExtSaveClick"/>
                                            <Button x:Name="btnExtTest" Content="Test Connection"
                                                    Padding="12,5" Margin="0,0,6,0"
                                                    Style="{StaticResource DarkButton}"
                                                    Click="OnExtTestClick"/>
                                            <TextBlock x:Name="tbExtStatus" Text="—"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="#556677" VerticalAlignment="Center"
                                                       Margin="10,0,0,0"/>
                                        </StackPanel>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>

                        <!-- Chat Test -->
                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Rectangle Width="3" Height="10" Fill="#00FFAA" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="CHAT TEST (MULTI-TURN SESSION)" FontSize="11" FontWeight="Bold"
                                               Foreground="#00FFAA" FontFamily="Consolas"/>
                                    <TextBlock x:Name="tbLlmTurnCount" Text="turns: 0" FontFamily="Consolas"
                                               FontSize="10" Foreground="#556677" Margin="12,0,0,0"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="btnLlmNewSession" Content="New Session"
                                            Padding="8,2" Margin="12,0,0,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmNewSessionClick" IsEnabled="False"/>
                                </StackPanel>
                                <Border Background="#0A0A14" BorderBrush="#2A2A5E" BorderThickness="1"
                                        Height="180" CornerRadius="2">
                                    <ScrollViewer x:Name="svLlmChat" VerticalScrollBarVisibility="Auto">
                                        <TextBox x:Name="tbLlmChatHistory" IsReadOnly="True"
                                                 TextWrapping="Wrap" AcceptsReturn="True"
                                                 BorderThickness="0" Background="Transparent"
                                                 Foreground="#C8C8D8" FontFamily="Consolas"
                                                 FontSize="10" Padding="8"/>
                                    </ScrollViewer>
                                </Border>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="tbLlmChatInput" Grid.Column="0"
                                             Style="{StaticResource DarkTextBox}"
                                             KeyDown="OnLlmChatInputKeyDown" IsEnabled="False"/>
                                    <Button x:Name="btnLlmChatSend" Grid.Column="1" Content="Send"
                                            Padding="12,5" Margin="8,0,0,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmChatSendClick" IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Monitor -->
                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Rectangle Width="3" Height="10" Fill="#FFB800" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="MONITOR" FontSize="11" FontWeight="Bold"
                                               Foreground="#FFB800" FontFamily="Consolas"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Process RAM" FontFamily="Consolas" FontSize="10" Foreground="#556677"/>
                                        <TextBlock x:Name="tbLlmRam" Text="—" FontFamily="Consolas"
                                                   FontSize="14" FontWeight="Bold" Foreground="#00E5FF"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="GPU Memory" FontFamily="Consolas" FontSize="10" Foreground="#556677"/>
                                        <TextBlock x:Name="tbLlmGpu" Text="—" FontFamily="Consolas"
                                                   FontSize="14" FontWeight="Bold" Foreground="#00FFAA"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Tokens/sec (last)" FontFamily="Consolas" FontSize="10" Foreground="#556677"/>
                                        <TextBlock x:Name="tbLlmTps" Text="—" FontFamily="Consolas"
                                                   FontSize="14" FontWeight="Bold" Foreground="#FFB800"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Voice LLM Tab -->
            <TabItem Header="&#x1F399; Voice" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">

                    <!-- STT (Speech-to-Text) -->
                    <Border Background="#1A1A2E" BorderBrush="#3E3E42"
                            BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="3" Height="10" Fill="#00E5FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="STT  (SPEECH &#x2192; TEXT)" FontSize="11" FontWeight="Bold"
                                           Foreground="#00E5FF" FontFamily="Consolas"/>
                                <TextBlock x:Name="tbSttStatus" Text="" FontFamily="Consolas"
                                           FontSize="10" Foreground="#556677" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Provider" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbSttProvider" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}"
                                          SelectionChanged="OnSttProviderChanged">
                                    <ComboBoxItem Content="Whisper Local  (offline, embedded)" Tag="WhisperLocal"/>
                                    <ComboBoxItem Content="OpenAI Whisper API" Tag="OpenAIWhisper"/>
                                    <ComboBoxItem Content="Webnori Gemma  (audio-capable)" Tag="WebnoriGemma"/>
                                    <ComboBoxItem Content="Local Gemma  (on-device, audio-capable)" Tag="LocalGemma"/>
                                </ComboBox>
                            </Grid>

                            <!-- WhisperLocal-specific: model + language + GPU -->
                            <StackPanel x:Name="spSttWhisperLocal" Visibility="Visible">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Whisper Model" FontFamily="Consolas" FontSize="10"
                                               Foreground="#888899" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cbSttWhisperModel" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}">
                                        <ComboBoxItem Content="tiny    (~75 MB, fastest, lowest accuracy)" Tag="tiny"/>
                                        <ComboBoxItem Content="small   (~466 MB, balanced — recommended)" Tag="small"/>
                                        <ComboBoxItem Content="medium  (~1.5 GB, slowest, best accuracy)" Tag="medium"/>
                                    </ComboBox>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Use GPU (Vulkan)" FontFamily="Consolas" FontSize="10"
                                               Foreground="#888899" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="chkSttUseGpu" Grid.Column="1"
                                              Content="cross-vendor (AMD/Intel/NVIDIA); falls back to CPU if Vulkan is unavailable"
                                              Foreground="#888899" FontFamily="Consolas" FontSize="10"
                                              VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="GPU device" FontFamily="Consolas" FontSize="10"
                                               Foreground="#888899" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cbSttGpuDevice" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"
                                              ToolTip="Auto = best (vendor + VRAM heuristic). Override on multi-GPU systems if Auto picks the wrong adapter."/>
                                </Grid>
                            </StackPanel>

                            <!-- OpenAIWhisper-specific: API key -->
                            <Grid x:Name="grdSttOpenAIKey" Margin="0,0,0,6" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="OpenAI API Key" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <PasswordBox x:Name="pbSttOpenAIKey" Grid.Column="1"
                                             Style="{StaticResource DarkPasswordBox}"/>
                            </Grid>

                            <!-- WebnoriGemma-specific: re-uses LLM-tab Webnori URL/key, only need model picker -->
                            <Grid x:Name="grdSttWebnoriModel" Margin="0,0,0,6" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Webnori Model" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbSttWebnoriModel" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}"/>
                                <Button x:Name="btnSttRefreshWebnoriModels" Grid.Column="2"
                                        Content="Refresh" Padding="10,3" Margin="6,0,0,0"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnSttRefreshWebnoriModels"/>
                            </Grid>

                            <!-- LocalGemma-specific: catalog model picker -->
                            <Grid x:Name="grdSttLocalGemmaModel" Margin="0,0,0,6" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Local Model" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbSttLocalGemmaModel" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}"/>
                            </Grid>

                            <!-- Common: language -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Language" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbSttLanguage" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}">
                                    <ComboBoxItem Content="auto  (provider auto-detects)" Tag="auto"/>
                                    <ComboBoxItem Content="ko  (Korean)" Tag="ko"/>
                                    <ComboBoxItem Content="en  (English)" Tag="en"/>
                                    <ComboBoxItem Content="ja  (Japanese)" Tag="ja"/>
                                    <ComboBoxItem Content="zh  (Chinese)" Tag="zh"/>
                                </ComboBox>
                            </Grid>

                            <DockPanel Margin="0,4,0,0">
                                <Button x:Name="btnSttSave" DockPanel.Dock="Right"
                                        Content="Save STT" Padding="14,5"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnSttSave"/>
                                <TextBlock x:Name="tbSttSaveStatus" FontFamily="Consolas" FontSize="10"
                                           Foreground="#556677" VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- M0024 — STT alone doesn't tell you WHO spoke. The Speaker
                                 Diarization section below layers Speaker A/B/C labels on
                                 top of any STT provider via Sherpa-ONNX (separate model). -->
                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#6688AA" LineHeight="14" Margin="0,6,0,0">
                                <Run>Want speaker labels (Speaker A / B / C)? See the </Run>
                                <Run FontWeight="Bold" Foreground="#9D7CFF">SPEAKER DIARIZATION</Run>
                                <Run> section below — it adds labels on top of any STT provider.</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- TTS (Text-to-Speech) -->
                    <Border Background="#1A1A2E" BorderBrush="#3E3E42"
                            BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="3" Height="10" Fill="#FFB800" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="TTS  (TEXT &#x2192; SPEECH)" FontSize="11" FontWeight="Bold"
                                           Foreground="#FFB800" FontFamily="Consolas"/>
                                <TextBlock x:Name="tbTtsStatus" Text="" FontFamily="Consolas"
                                           FontSize="10" Foreground="#556677" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Provider" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbTtsProvider" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}"
                                          SelectionChanged="OnTtsProviderChanged">
                                    <ComboBoxItem Content="Off  (no voice output)" Tag="Off"/>
                                    <ComboBoxItem Content="Windows TTS  (System.Speech, offline)" Tag="WindowsTTS"/>
                                    <ComboBoxItem Content="OpenAI TTS  (tts-1)" Tag="OpenAITTS"/>
                                    <ComboBoxItem Content="Supertonic  (native on-device ONNX)" Tag="Supertonic"/>
                                </ComboBox>
                            </Grid>

                            <Grid x:Name="grdTtsVoice" Margin="0,0,0,6" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Voice" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbTtsVoice" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}"/>
                                <Button x:Name="btnTtsRefreshVoices" Grid.Column="2"
                                        Content="Refresh" Padding="10,3" Margin="6,0,0,0"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnTtsRefreshVoices"/>
                            </Grid>

                            <Grid x:Name="grdTtsOpenAIKey" Margin="0,0,0,6" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="OpenAI API Key" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <PasswordBox x:Name="pbTtsOpenAIKey" Grid.Column="1"
                                             Style="{StaticResource DarkPasswordBox}"/>
                            </Grid>

                            <StackPanel x:Name="spTtsSupertonic" Visibility="Collapsed">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Voice" FontFamily="Consolas" FontSize="10"
                                               Foreground="#888899" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cbSupertonicVoice" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"
                                              SelectionChanged="OnSupertonicFieldChanged"
                                              ToolTip="Builtin Supertonic voices — M1..M5 (male), F1..F5 (female).">
                                        <ComboBoxItem Content="F1  (female)" Tag="F1"/>
                                        <ComboBoxItem Content="F2  (female)" Tag="F2"/>
                                        <ComboBoxItem Content="F3  (female)" Tag="F3"/>
                                        <ComboBoxItem Content="F4  (female)" Tag="F4"/>
                                        <ComboBoxItem Content="F5  (female)" Tag="F5"/>
                                        <ComboBoxItem Content="M1  (male)" Tag="M1"/>
                                        <ComboBoxItem Content="M2  (male)" Tag="M2"/>
                                        <ComboBoxItem Content="M3  (male)" Tag="M3"/>
                                        <ComboBoxItem Content="M4  (male)" Tag="M4"/>
                                        <ComboBoxItem Content="M5  (male)" Tag="M5"/>
                                    </ComboBox>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Model" FontFamily="Consolas" FontSize="10"
                                               Foreground="#888899" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" FontFamily="Consolas" FontSize="10"
                                               Foreground="#808080" TextWrapping="Wrap" LineHeight="14"
                                               VerticalAlignment="Center">
                                        <Run>One-time ~398 MB download. Click </Run>
                                        <Run FontWeight="Bold" Foreground="#00FFAA">Download Model</Run>
                                        <Run> before first synthesis — runs fully on-device afterwards.</Run>
                                    </TextBlock>
                                    <Button x:Name="btnSupertonicDownloadModel" Grid.Column="2"
                                            Content="Download Model" Padding="10,3" Margin="6,0,0,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnSupertonicDownloadModel"/>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Language" FontFamily="Consolas" FontSize="10"
                                               Foreground="#888899" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cbSupertonicLang" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"
                                              SelectionChanged="OnSupertonicFieldChanged">
                                        <ComboBoxItem Content="Korean  (ko)" Tag="ko"/>
                                        <ComboBoxItem Content="English  (en)" Tag="en"/>
                                        <ComboBoxItem Content="Japanese  (ja)" Tag="ja"/>
                                        <ComboBoxItem Content="Auto  (na — script-detect)" Tag="na"/>
                                    </ComboBox>
                                    <TextBox x:Name="tbSupertonicSteps" Grid.Column="2" Margin="6,0,0,0"
                                             Style="{StaticResource DarkTextBox}"
                                             TextChanged="OnSupertonicFieldChanged"
                                             ToolTip="ONNX steps 5..12 (default 8). Higher = better quality, lower = faster."/>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Speed" FontFamily="Consolas" FontSize="10"
                                               Foreground="#888899" VerticalAlignment="Center"/>
                                    <TextBox x:Name="tbSupertonicSpeed" Grid.Column="1"
                                             Style="{StaticResource DarkTextBox}"
                                             TextChanged="OnSupertonicFieldChanged"
                                             ToolTip="Speech speed factor 0.7..2.0 (default 1.05). Higher = faster."/>
                                </Grid>

                                <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                           Foreground="#808080" LineHeight="14" Margin="0,0,0,6">
                                    <Run>Native ONNX — no Python, no pip. Models cache to </Run>
                                    <Run FontWeight="Bold" Foreground="#FFB347">%LOCALAPPDATA%\AgentZeroLite\models\supertonic</Run>
                                    <Run>. 44.1 kHz WAV, 31 languages. Model is OpenRAIL-M licensed.</Run>
                                </TextBlock>
                            </StackPanel>

                            <DockPanel Margin="0,4,0,0">
                                <Button x:Name="btnTtsSave" DockPanel.Dock="Right"
                                        Content="Save TTS" Padding="14,5"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnTtsSave"/>
                                <TextBlock x:Name="tbTtsSaveStatus" FontFamily="Consolas" FontSize="10"
                                           Foreground="#556677" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- SPEAKER DIARIZATION (M0024) — separate from STT because it's a
                         distinct model family layered ON TOP of any STT provider.
                         Sherpa-ONNX (pyannote-3.0 + 3D-Speaker) is the default and only
                         provider for the first iteration; the combo stays open so MERT /
                         CLAP / pyannote-subprocess can be added later without UI churn. -->
                    <Border Background="#1A1A2E" BorderBrush="#3E3E42"
                            BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="3" Height="10" Fill="#9D7CFF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="SPEAKER DIARIZATION  (WHO SPOKE WHEN)" FontSize="11" FontWeight="Bold"
                                           Foreground="#9D7CFF" FontFamily="Consolas"/>
                                <TextBlock x:Name="tbDiarStatus" Text="" FontFamily="Consolas"
                                           FontSize="10" Foreground="#556677" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Provider" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbDiarProvider" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}"
                                          SelectionChanged="OnDiarProviderChanged">
                                    <ComboBoxItem Content="Off  (no speaker labels)" Tag="Off"/>
                                    <ComboBoxItem Content="Sherpa-ONNX  (pyannote-3.0 + 3D-Speaker, ~50 MB, on-device)" Tag="SherpaPyannote3D"/>
                                </ComboBox>
                            </Grid>

                            <StackPanel x:Name="spDiarSherpa" Visibility="Collapsed">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Segmentation" FontFamily="Consolas" FontSize="10"
                                               Foreground="#888899" VerticalAlignment="Center"/>
                                    <TextBox x:Name="tbDiarSegPath" Grid.Column="1"
                                             Background="#2A2A3E" Foreground="#C8C8D8"
                                             BorderBrush="#3E3E42" Padding="6,3"
                                             FontFamily="Consolas" FontSize="10"
                                             ToolTip="pyannote-segmentation-3-0/model.onnx — empty = default cache path."/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
                                        <Button x:Name="btnDiarCheck"
                                                Content="Check" Padding="10,3" Margin="0,0,4,0"
                                                Style="{StaticResource DarkButton}"
                                                Click="OnDiarCheckModel"/>
                                        <Button x:Name="btnDiarDownload"
                                                Content="Download" Padding="10,3"
                                                Style="{StaticResource DarkButton}"
                                                Click="OnDiarDownloadModel"
                                                ToolTip="Pull pyannote-segmentation + 3D-Speaker (~50 MB total) from k2-fsa GitHub releases."/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Embedding" FontFamily="Consolas" FontSize="10"
                                               Foreground="#888899" VerticalAlignment="Center"/>
                                    <TextBox x:Name="tbDiarEmbPath" Grid.Column="1"
                                             Background="#2A2A3E" Foreground="#C8C8D8"
                                             BorderBrush="#3E3E42" Padding="6,3"
                                             FontFamily="Consolas" FontSize="10"
                                             ToolTip="3D-Speaker ERes2Net embedding .onnx — empty = default cache path."/>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Expected Spkrs" FontFamily="Consolas" FontSize="10"
                                               Foreground="#888899" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cbDiarExpectedSpeakers" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}"
                                              ToolTip="auto = let the embedding clusterer pick. Set a fixed number when you know the room (e.g. 2 for an interview).">
                                        <ComboBoxItem Content="auto  (let model cluster)" Tag="0" IsSelected="True"/>
                                        <ComboBoxItem Content="2"  Tag="2"/>
                                        <ComboBoxItem Content="3"  Tag="3"/>
                                        <ComboBoxItem Content="4"  Tag="4"/>
                                        <ComboBoxItem Content="5+" Tag="5"/>
                                    </ComboBox>
                                </Grid>

                                <Border Background="#0F0F1A" BorderBrush="#2A2A3E"
                                        BorderThickness="1" CornerRadius="2" Padding="8,6" Margin="0,4,0,0">
                                    <StackPanel>
                                        <TextBlock Text="HOW IT WORKS" FontSize="9" FontWeight="Bold"
                                                   Foreground="#6688AA" FontFamily="Consolas" Margin="0,0,0,4"/>
                                        <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#888899"
                                                   TextWrapping="Wrap">
                                            <Run>Same captured audio goes to STT (speech → text) and to the diarizer (audio → speaker spans) in parallel. </Run>
                                            <Run>Voice test prepends </Run>
                                            <Run FontWeight="Bold" Foreground="#00E5FF">[Speaker A]</Run>
                                            <Run> / </Run>
                                            <Run FontWeight="Bold" Foreground="#C586C0">[Speaker B]</Run>
                                            <Run> labels to each transcript line.</Run>
                                            <LineBreak/>
                                            <Run>Models pull from k2-fsa GitHub releases — </Run>
                                            <Run FontWeight="Bold" Foreground="#FFB347">~50 MB total</Run>
                                            <Run>, one-time download, no Python required.</Run>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <DockPanel Margin="0,8,0,0">
                                <Button x:Name="btnDiarSave" DockPanel.Dock="Right"
                                        Content="Save Diarization" Padding="14,5"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnDiarSave"/>
                                <TextBlock x:Name="tbDiarSaveStatus" FontFamily="Consolas" FontSize="10"
                                           Foreground="#556677" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Voice Test -->
                    <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                            CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="3" Height="10" Fill="#FF2D95" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="VOICE TEST  (MIC &#x2192; STT &#x2192; LLM &#x2192; TTS)" FontSize="11" FontWeight="Bold"
                                           Foreground="#FF2D95" FontFamily="Consolas"/>
                                <TextBlock x:Name="tbVoiceTestActiveLlm" Text="LLM: —" FontFamily="Consolas"
                                           FontSize="10" Foreground="#556677" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#808080" LineHeight="16" Margin="0,0,0,6">
                                <Run>Voice Test routes through </Run>
                                <Run FontWeight="Bold" Foreground="#00FFAA">the LLM picked on the LLM tab</Run>
                                <Run>. No separate Voice-LLM provider is exposed.</Run>
                            </TextBlock>

                            <!-- M0024 — Voice test gains the same dual capture source as
                                 the Music tab: mic (NAudio WaveIn) or system output
                                 (WASAPI loopback). Loopback option is most useful for
                                 diarization smoke tests against a recorded meeting clip
                                 played back through the speakers. -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Source" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbVoiceInputSource" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}"
                                          SelectionChanged="OnVoiceInputSourceChanged"
                                          ToolTip="Microphone = NAudio WaveIn. System Output = WASAPI loopback (what's playing on the speakers — e.g. a recorded interview).">
                                    <ComboBoxItem Content="Microphone  (mic input)" Tag="Microphone"/>
                                    <ComboBoxItem Content="System Output  (WASAPI loopback — what's playing on your speakers)" Tag="SystemLoopback"/>
                                </ComboBox>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="tbVoiceDeviceLabel" Text="Mic Device" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbVoiceInputDevice" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}"/>
                                <Button x:Name="btnVoiceRefreshDevices" Grid.Column="2"
                                        Content="Refresh" Padding="10,3" Margin="6,0,0,0"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnVoiceRefreshDevices"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Mode" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <RadioButton x:Name="rbVoiceModeAuto" GroupName="VoiceMode"
                                                 Content="Auto VAD  (silence-segmented)"
                                                 Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                 VerticalAlignment="Center" Margin="0,0,16,0" IsChecked="True"/>
                                    <RadioButton x:Name="rbVoiceModeManual" GroupName="VoiceMode"
                                                 Content="Manual  (START / STOP)"
                                                 Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                 VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sensitivity" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <Slider x:Name="slVoiceSensitivity" Grid.Column="1"
                                        Minimum="0" Maximum="100" Value="75"
                                        TickFrequency="5" IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="tbVoiceSensitivityValue" Grid.Column="2"
                                           Text="75" FontFamily="Consolas" FontSize="10"
                                           Foreground="#00E5FF" VerticalAlignment="Center" MinWidth="32"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Max Tokens" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"
                                           ToolTip="Cap on the AI reply length so TTS playback stays short. 128 ≈ 5–10 s. Applies to External LLM (Webnori/OpenAI/LMStudio/Ollama); Local uses the LLM-tab cap because LlmService loads MaxTokens at model-load time."/>
                                <TextBox x:Name="tbVoiceLlmMaxTokens" Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}" Width="100"
                                         HorizontalAlignment="Left"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Level" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Background="#0A0A14" BorderBrush="#2A2A5E"
                                        BorderThickness="1" Height="14" CornerRadius="1">
                                    <ProgressBar x:Name="pbVoiceLevel" Minimum="0" Maximum="100" Value="0"
                                                 Background="Transparent" Foreground="#00FFAA"
                                                 BorderThickness="0"/>
                                </Border>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="tbVoiceTestStatus" Grid.Column="0"
                                           Text="Idle" FontFamily="Consolas" FontSize="10"
                                           Foreground="#556677" VerticalAlignment="Center"/>
                                <!-- Cuts off the AI's current speech + cancels the in-flight
                                     pipeline, but keeps the session alive (mic stays hot).
                                     Disabled while idle. -->
                                <Button x:Name="btnVoiceInterrupt" Grid.Column="1"
                                        Content="INTERRUPT" Padding="14,5" Margin="0,0,8,0"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnVoiceInterrupt" IsEnabled="False"/>
                                <Button x:Name="btnVoiceTestStart" Grid.Column="2"
                                        Content="START" Padding="14,5"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnVoiceTestStartStop"/>
                            </Grid>

                            <Border Background="#0A0A14" BorderBrush="#2A2A5E" BorderThickness="1"
                                    Height="120" CornerRadius="2" Margin="0,0,0,4">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBox x:Name="tbVoiceTranscript" IsReadOnly="True"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             BorderThickness="0" Background="Transparent"
                                             Foreground="#C8C8D8" FontFamily="Consolas"
                                             FontSize="10" Padding="8"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Music LLM Tab — instrument classification + log-mel spectrum
                 via AST AudioSet ONNX. Mirrors the Voice tab layout: provider
                 block → test block. Provider is locked to a single fixed
                 model for the first iteration; the field stays as a ComboBox
                 so MERT / CLAP can be added later without UI churn. -->
            <TabItem Header="&#x1F3B5; Music" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">

                    <!-- Model -->
                    <Border Background="#1A1A2E" BorderBrush="#3E3E42"
                            BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="3" Height="10" Fill="#B388FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="MODEL  (AUDIO &#x2192; INSTRUMENT + SPECTRUM)" FontSize="11" FontWeight="Bold"
                                           Foreground="#B388FF" FontFamily="Consolas"/>
                                <TextBlock x:Name="tbMusicModelStatus" Text="" FontFamily="Consolas"
                                           FontSize="10" Foreground="#556677" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Provider" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbMusicProvider" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}" IsEnabled="False">
                                    <ComboBoxItem Content="AST AudioSet  (MIT, 86.6M, 527 labels — locked)" Tag="ASTAudioSet" IsSelected="True"/>
                                </ComboBox>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Model Path" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <TextBox x:Name="tbMusicModelPath" Grid.Column="1"
                                         Background="#2A2A3E" Foreground="#C8C8D8"
                                         BorderBrush="#3E3E42" Padding="6,3"
                                         FontFamily="Consolas" FontSize="10"
                                         ToolTip="Absolute path to the AST ONNX model. Empty = use convention path under %LOCALAPPDATA%\AgentZeroLite\models\ast-audioset\model.onnx"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
                                    <Button x:Name="btnMusicCheckModel"
                                            Content="Check" Padding="10,3" Margin="0,0,4,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnMusicCheckModel"/>
                                    <Button x:Name="btnMusicDownload"
                                            Content="Download" Padding="10,3"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnMusicDownloadModel"
                                            ToolTip="Pull model.onnx (~347 MB) + AudioSet labels from HuggingFace into the path above."/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Labels CSV" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <TextBox x:Name="tbMusicLabelsPath" Grid.Column="1"
                                         Background="#2A2A3E" Foreground="#C8C8D8"
                                         BorderBrush="#3E3E42" Padding="6,3"
                                         FontFamily="Consolas" FontSize="10"
                                         ToolTip="Path to Google's class_labels_indices.csv (AudioSet 527). Missing = numeric class indices instead of names."/>
                            </Grid>

                            <Border Background="#0F0F1A" BorderBrush="#2A2A3E"
                                    BorderThickness="1" CornerRadius="2" Padding="8,6" Margin="0,4,0,0">
                                <StackPanel>
                                    <TextBlock Text="HOW TO INSTALL THE MODEL" FontSize="9" FontWeight="Bold"
                                               Foreground="#6688AA" FontFamily="Consolas" Margin="0,0,0,4"/>
                                    <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#888899"
                                               TextWrapping="Wrap">
                                        <Run Text="1. pip install optimum[onnxruntime]"/>
                                        <LineBreak/>
                                        <Run Text="2. optimum-cli export onnx --model MIT/ast-finetuned-audioset-10-10-0.4593 ast-audioset/"/>
                                        <LineBreak/>
                                        <Run Text="3. Drop model.onnx into the path above (~346 MB)"/>
                                        <LineBreak/>
                                        <Run Text="4. (Optional) class_labels_indices.csv from Google's AudioSet release"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <DockPanel Margin="0,8,0,0">
                                <Button x:Name="btnMusicSave" DockPanel.Dock="Right"
                                        Content="Save Music" Padding="14,5"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnMusicSave"/>
                                <TextBlock x:Name="tbMusicSaveStatus" FontFamily="Consolas" FontSize="10"
                                           Foreground="#556677" VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Test -->
                    <Border Background="#1A1A2E" BorderBrush="#3E3E42"
                            BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="3" Height="10" Fill="#00E5FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="MUSIC TEST" FontSize="11" FontWeight="Bold"
                                           Foreground="#00E5FF" FontFamily="Consolas"/>
                                <TextBlock x:Name="tbMusicTestStatus" Text="" FontFamily="Consolas"
                                           FontSize="10" Foreground="#556677" Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Source" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbMusicInputSource" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}"
                                          SelectionChanged="OnMusicInputSourceChanged"
                                          ToolTip="Microphone = NAudio WaveIn (mic input). System Output = WASAPI loopback (whatever is playing on your speakers — Spotify, YouTube, game audio).">
                                    <ComboBoxItem Content="Microphone  (mic input)" Tag="Microphone"/>
                                    <ComboBoxItem Content="System Output  (WASAPI loopback — what's playing on your speakers)" Tag="SystemLoopback"/>
                                </ComboBox>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="tbMusicDeviceLabel" Text="Input Device" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <ComboBox x:Name="cbMusicInputDevice" Grid.Column="1"
                                          Style="{StaticResource DarkComboBox}"/>
                                <Button x:Name="btnMusicRefreshDevices" Grid.Column="2"
                                        Content="Refresh" Padding="10,3" Margin="6,0,0,0"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnMusicRefreshDevices"/>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Window (s)" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center"/>
                                <TextBox x:Name="tbMusicDuration" Grid.Column="1"
                                         Background="#2A2A3E" Foreground="#C8C8D8"
                                         BorderBrush="#3E3E42" Padding="6,3"
                                         FontFamily="Consolas" FontSize="10"
                                         ToolTip="Sliding window — how many seconds of recent audio AST sees on each inference tick. AST is trained on 10s clips; shorter windows infer faster but lose accuracy. 1..30."/>
                                <TextBlock Grid.Column="2" Text=""/>
                                <TextBlock Grid.Column="3" Text="Top-K" FontFamily="Consolas" FontSize="10"
                                           Foreground="#888899" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,6,0"/>
                                <TextBox x:Name="tbMusicTopK" Grid.Column="4"
                                         Background="#2A2A3E" Foreground="#C8C8D8"
                                         BorderBrush="#3E3E42" Padding="6,3"
                                         FontFamily="Consolas" FontSize="10"
                                         ToolTip="Number of top labels to show. 1..20."/>
                            </Grid>

                            <DockPanel Margin="0,4,0,6">
                                <Button x:Name="btnMusicTest" DockPanel.Dock="Right"
                                        Content="START TEST" Padding="14,5"
                                        Style="{StaticResource DarkButton}"
                                        Click="OnMusicTestStartStop"/>
                                <ProgressBar x:Name="pbMusicLevel" Height="14" Margin="0,0,8,0"
                                             Background="#0F0F1A" Foreground="#00E5FF"
                                             Minimum="0" Maximum="100" Value="0"/>
                            </DockPanel>

                            <TextBlock Text="SPECTRUM  (30 Hz – 8 kHz, log-frequency)" FontSize="9" FontWeight="Bold"
                                       Foreground="#6688AA" FontFamily="Consolas" Margin="0,4,0,2"/>
                            <Border Background="#080812" BorderBrush="#2A2A3E"
                                    BorderThickness="1" CornerRadius="2" Height="120" Margin="0,0,0,6">
                                <Canvas x:Name="cvMusicSpectrum"
                                        ClipToBounds="True" SnapsToDevicePixels="True"
                                        SizeChanged="OnMusicSpectrumSizeChanged"/>
                            </Border>

                            <TextBlock Text="TOP LABELS  (live · sliding 10 s window)" FontSize="9" FontWeight="Bold"
                                       Foreground="#6688AA" FontFamily="Consolas" Margin="0,2,0,2"/>
                            <Border Background="#0F0F1A" BorderBrush="#2A2A3E"
                                    BorderThickness="1" CornerRadius="2" MinHeight="140">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                                    <TextBox x:Name="tbMusicResults" IsReadOnly="True"
                                             BorderThickness="0" Background="Transparent"
                                             Foreground="#C8C8D8" FontFamily="Consolas"
                                             FontSize="11" Padding="8" TextWrapping="NoWrap"/>
                                </ScrollViewer>
                            </Border>

                        </StackPanel>
                    </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- WebDev Tab — moved to MainWindow activity bar (M0006).
                 What used to be a cramped 480-px-wide WebView2 tab now lives
                 as a top-level main menu (globe icon next to Agent Bot).
                 This tab keeps a tutorial / plugin-author guide so people who
                 land in Settings looking for "WebDev" still find the bridge
                 surface and the .zip plugin install workflow. -->
            <TabItem x:Name="tabWebDev" Header="&#x1F310; WebDev" Style="{StaticResource SettingsTabItem}">
                <components:WebDevTutorialPanel/>
            </TabItem>

            <!-- AgentZero CLI Tab -->
            <TabItem Header="&#x1F4BB; AgentZero CLI" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">

                    <!-- Path Setup -->
                    <Border Background="#1A1A2E" BorderBrush="#3E3E42"
                            BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="3" Height="10" Fill="#FF2D95" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="PATH SETUP" FontSize="11" FontWeight="Bold"
                                           Foreground="#FF2D95" FontFamily="Consolas"/>
                            </StackPanel>
                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#808080" LineHeight="16"
                                       Margin="0,0,0,6">
                                <Run>Register AgentZero CLI path to user PATH environment variable.</Run>
                                <LineBreak/>
                                <Run>After registration, AgentZeroLite.ps1 can be used from anywhere.</Run>
                            </TextBlock>
                            <DockPanel Margin="0,0,0,4">
                                <Button x:Name="btnRegisterPath" DockPanel.Dock="Right"
                                        Content="Register PATH" Padding="14,5"
                                        FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                        Foreground="#00FFF0" Background="#14143A"
                                        BorderBrush="#2A2A5E" BorderThickness="1"
                                        Cursor="Hand" Click="OnRegisterPath"
                                        Margin="8,0,0,0"/>
                                <TextBox x:Name="tbCurrentPath" IsReadOnly="True"
                                         Background="#12122A" Foreground="#556677"
                                         BorderBrush="#2A2A5E" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="10"
                                         Padding="8,4" VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <TextBlock x:Name="lblPathStatus" FontFamily="Consolas" FontSize="10"
                                       Foreground="#556677" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- AI ↔ AI Talk (teach the CLI to Claude / Codex) -->
                    <Border Background="#1A1A2E" BorderBrush="#3E3E42"
                            BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="3" Height="10" Fill="#8B00FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="AI &#x2194; AI TALK" FontSize="11" FontWeight="Bold"
                                           Foreground="#8B00FF" FontFamily="Consolas"/>
                            </StackPanel>

                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#C8C8D8" LineHeight="16"
                                       Margin="0,0,0,6">
                                <Run FontWeight="Bold" Foreground="#00FFF0">Teach the CLI to your AI once — they can talk to each other forever.</Run>
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#808080" LineHeight="16"
                                       Margin="0,0,0,6">
                                <Run>After PATH registration, open a Claude / Codex tab and paste:</Run>
                            </TextBlock>

                            <Border Background="#0A0A14" BorderBrush="#2A2A5E" BorderThickness="1"
                                    CornerRadius="2" Padding="8,6" Margin="0,0,0,8">
                                <TextBox IsReadOnly="True" BorderThickness="0"
                                         Background="Transparent" Foreground="#B5CEA8"
                                         FontFamily="Consolas" FontSize="10"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         Text="Learn `AgentZeroLite.ps1 help` and use it for cross-terminal talk.&#x0a;Use `terminal-list` to see the tabs, `terminal-send &lt;grp&gt; &lt;tab&gt; &quot;text&quot;` to speak to another AI tab by name."/>
                            </Border>

                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#808080" LineHeight="16"
                                       Margin="0,0,0,6">
                                <Run>Then say, for example:</Run>
                            </TextBlock>

                            <Border Background="#0A0A14" BorderBrush="#2A2A5E" BorderThickness="1"
                                    CornerRadius="2" Padding="8,6">
                                <TextBox IsReadOnly="True" BorderThickness="0"
                                         Background="Transparent" Foreground="#C8C8D8"
                                         FontFamily="Consolas" FontSize="10"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         Text="&#x25B8; You (in Claude tab):  Greet the tab named Codex.&#x0a;&#x25B8; Claude runs:           AgentZeroLite.ps1 terminal-send 0 1 &quot;hi Codex, this is Claude&quot;&#x0a;&#x25B8; Codex replies back:    AgentZeroLite.ps1 terminal-send 0 0 &quot;hey Claude, let's design the API&quot;&#x0a;&#x25B8; Each AI reads the peer's reply with: terminal-read 0 &lt;peer-tab&gt; --last 2000"/>
                            </Border>

                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#556677" LineHeight="16"
                                       Margin="0,6,0,0">
                                <Run>No shared memory, no broker — the shell pipes through AgentZero's</Run>
                                <LineBreak/>
                                <Run>IPC (WM_COPYDATA + memory-mapped files). You stay in control.</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
