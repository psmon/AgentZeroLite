<UserControl x:Class="AgentZeroWpf.UI.Components.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:AgentZeroWpf.UI.Components"
             Background="#08081A">

    <UserControl.Resources>
        <!-- Dark TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="CaretBrush" Value="#00E5FF"/>
            <Setter Property="BorderBrush" Value="#2A2A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>

        <!-- Dark ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#2A2A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn" Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" Background="Transparent">
                                                    <TextBlock Text="▾" Foreground="#556677"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               FontSize="10"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,3,24,3" VerticalAlignment="Center"
                                              HorizontalAlignment="Left" IsHitTestVisible="False"/>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                        MaxHeight="200" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#264F78"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0D4477"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark PasswordBox -->
        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#12122A"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="CaretBrush" Value="#00E5FF"/>
            <Setter Property="BorderBrush" Value="#2A2A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>

        <!-- Dark Button -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00E5FF"/>
            <Setter Property="Background" Value="#14143A"/>
            <Setter Property="BorderBrush" Value="#2A2A5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E1E5E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A0A2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab item style -->
        <Style x:Key="SettingsTabItem" TargetType="TabItem">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#556677"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Cursor="Hand">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#00FFF0"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00FFF0"/>
                                <Setter TargetName="Bd" Property="Background" Value="#0D0D1A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#12122A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="True">
            <Button x:Name="btnSettingsClose" DockPanel.Dock="Right"
                    Content="&#x2715;" Width="28" Height="22" Padding="0"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#888899" FontSize="13" FontFamily="Segoe UI"
                    Cursor="Hand" ToolTip="닫기 (일반 화면으로)"
                    Click="OnSettingsCloseClick">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            BorderThickness="0" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Rectangle Width="3" Height="14" Fill="#00E5FF" RadiusX="1" RadiusY="1" Margin="0,0,8,0"/>
                <TextBlock Text="SETTINGS" FontSize="14" FontWeight="Bold"
                           Foreground="#00E5FF" FontFamily="Consolas"/>
            </StackPanel>
        </DockPanel>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    Padding="0">
            <!-- CLI Definitions Tab -->
            <TabItem Header="&#x2699; CLI Definitions" Style="{StaticResource SettingsTabItem}">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="2"
                            Background="#1E1E1E">
                        <ListView x:Name="lvCliDefs" Background="Transparent" BorderThickness="0"
                                  Foreground="#D4D4D4" FontFamily="Consolas" FontSize="12"
                                  SelectionChanged="OnCliDefSelectionChanged">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="100"
                                                    DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="ExePath" Width="200"
                                                    DisplayMemberBinding="{Binding ExePath}"/>
                                    <GridViewColumn Header="Args" Width="100"
                                                    DisplayMemberBinding="{Binding Arguments}"/>
                                    <GridViewColumn Header="BuiltIn" Width="60"
                                                    DisplayMemberBinding="{Binding IsBuiltIn}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Left">
                        <Button Content="+ ADD" Padding="12,6" Margin="0,0,6,0"
                                FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                Foreground="#00E5FF" Background="#2D2D30"
                                BorderBrush="#3E3E42" BorderThickness="1"
                                Cursor="Hand" Click="OnAddCliDef"/>
                        <Button x:Name="btnEditCliDef" Content="EDIT" Padding="12,6" Margin="0,0,6,0"
                                FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                Foreground="#D4D4D4" Background="#2D2D30"
                                BorderBrush="#3E3E42" BorderThickness="1"
                                Cursor="Hand" Click="OnEditCliDef" IsEnabled="False"/>
                        <Button x:Name="btnDelCliDef" Content="DELETE" Padding="12,6"
                                FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                Foreground="#D13438" Background="#2D2D30"
                                BorderBrush="#3E3E42" BorderThickness="1"
                                Cursor="Hand" Click="OnDeleteCliDef" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- LLM (Gemma) Tab -->
            <TabItem Header="&#x1F916; LLM (Gemma)" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">

                        <!-- Experimental Banner -->
                        <Border Background="#2A0E1F" BorderBrush="#FF2D95" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#x26A0;" FontSize="14" Foreground="#FF2D95"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="온디바이스 실험중" FontSize="13" FontWeight="Bold"
                                               Foreground="#FF2D95" FontFamily="Consolas"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                           Foreground="#E0C8D8" LineHeight="16">
                                    <Run>AgentBot AI Mode의 온디바이스 탑재를 위해 시도되고 있는 기능입니다.</Run>
                                    <LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#00FFAA">CPU 백엔드는 테스트 통과</Run><Run> — Load / 멀티턴 채팅 / 함수콜 모두 안정.</Run>
                                    <LineBreak/>
                                    <Run FontWeight="Bold" Foreground="#FF2D95">GPU(Vulkan) 백엔드는 아직 불안정</Run><Run> — Gemma 4 + Vulkan 조합의 네이티브 크래시 원인들을 추적 중.</Run>
                                    <LineBreak/>
                                    <Run Foreground="#888899">세부 실패 사례: Docs/gemma4-gpu-load-failures.md</Run>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Model Status -->
                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Rectangle Width="3" Height="10" Fill="#00E5FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="MODEL" FontSize="11" FontWeight="Bold"
                                               Foreground="#00E5FF" FontFamily="Consolas"/>
                                    <TextBlock x:Name="tbLlmModelState" Text="[Missing]" FontSize="10"
                                               Foreground="#FF2D95" FontFamily="Consolas"
                                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ComboBox x:Name="cbLlmModel" Style="{StaticResource DarkComboBox}"
                                          Margin="0,0,0,6"
                                          SelectionChanged="OnLlmModelSelectionChanged"/>
                                <TextBox x:Name="tbLlmModelPath" Style="{StaticResource DarkTextBox}"
                                         IsReadOnly="True" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar x:Name="pbLlmDownload" Grid.Column="0" Height="14"
                                                 Minimum="0" Maximum="100" Value="0"
                                                 Foreground="#00E5FF" Background="#12122A"
                                                 BorderBrush="#2A2A5E"/>
                                    <Button x:Name="btnLlmDownload" Grid.Column="1"
                                            Content="Download" Padding="12,5" Margin="8,0,0,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmDownloadClick"/>
                                </Grid>
                                <TextBlock x:Name="tbLlmDownloadStatus" FontFamily="Consolas" FontSize="10"
                                           Foreground="#556677" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Runtime Options -->
                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Rectangle Width="3" Height="10" Fill="#8B00FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="RUNTIME OPTIONS" FontSize="11" FontWeight="Bold"
                                               Foreground="#8B00FF" FontFamily="Consolas"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Backend" Grid.Row="0" Grid.Column="0"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                    <ComboBox x:Name="cbLlmBackend" Grid.Row="0" Grid.Column="1"
                                              Style="{StaticResource DarkComboBox}" Margin="0,3,12,3">
                                        <ComboBoxItem Content="Cpu"/>
                                        <ComboBoxItem Content="Vulkan"/>
                                    </ComboBox>

                                    <TextBlock Text="GPU Layers" Grid.Row="0" Grid.Column="2"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                    <TextBox x:Name="tbLlmGpuLayers" Grid.Row="0" Grid.Column="3"
                                             Style="{StaticResource DarkTextBox}" Margin="0,3,0,3"/>

                                    <TextBlock Text="GPU Device" Grid.Row="2" Grid.Column="2"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                    <ComboBox x:Name="cbLlmGpuDevice" Grid.Row="2" Grid.Column="3"
                                              Style="{StaticResource DarkComboBox}" Margin="0,3,0,3"/>

                                    <TextBlock Text="Context Size" Grid.Row="1" Grid.Column="0"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                    <TextBox x:Name="tbLlmContextSize" Grid.Row="1" Grid.Column="1"
                                             Style="{StaticResource DarkTextBox}" Margin="0,3,12,3"/>

                                    <TextBlock Text="Chat MaxTok" Grid.Row="1" Grid.Column="2"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"
                                               ToolTip="TestBot free-form answer length cap. Not used by AIMODE."/>
                                    <TextBox x:Name="tbLlmMaxTokens" Grid.Row="1" Grid.Column="3"
                                             Style="{StaticResource DarkTextBox}" Margin="0,3,0,3"/>

                                    <TextBlock Text="Temperature" Grid.Row="2" Grid.Column="0"
                                               Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"/>
                                    <TextBox x:Name="tbLlmTemperature" Grid.Row="2" Grid.Column="1"
                                             Style="{StaticResource DarkTextBox}" Margin="0,3,12,3"/>

                                    <TextBlock Text="AIMODE MaxTok" Grid.Row="3" Grid.Column="0"
                                               Foreground="#9D87FF" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,3,6,3"
                                               ToolTip="Per-turn token budget for the AIMODE tool-call loop. Default 2048. Lower = faster fail on grammar trailing-whitespace stall but risks `done` JSON truncation."/>
                                    <TextBox x:Name="tbLlmAgentLoopMaxTokens" Grid.Row="3" Grid.Column="1"
                                             Style="{StaticResource DarkTextBox}" Margin="0,3,12,3"/>
                                    <TextBlock Text="(per AIMODE turn)" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2"
                                               Foreground="#7C7C8C" FontFamily="Consolas" FontSize="9"
                                               VerticalAlignment="Center" Margin="0,3,0,3"/>
                                </Grid>

                                <!-- KV Cache & Attention (experimental, user-tunable) -->
                                <Border BorderBrush="#2A2A5E" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
                                    <StackPanel>
                                        <TextBlock Text="KV CACHE / ATTENTION (experimental)"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="#FF2D95" FontFamily="Consolas"
                                                   Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Flash Attention" Grid.Row="0" Grid.Column="0"
                                                       Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,3,6,3"/>
                                            <CheckBox x:Name="chkLlmFlashAttn" Grid.Row="0" Grid.Column="1"
                                                      Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                      VerticalAlignment="Center" Margin="0,3,12,3"
                                                      Content="enable"/>

                                            <TextBlock Text="No KQV Offload" Grid.Row="0" Grid.Column="2"
                                                       Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,3,6,3"/>
                                            <CheckBox x:Name="chkLlmNoKqvOffload" Grid.Row="0" Grid.Column="3"
                                                      Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                      VerticalAlignment="Center" Margin="0,3,0,3"
                                                      Content="KV stays on CPU RAM"/>

                                            <TextBlock Text="KV Type K" Grid.Row="1" Grid.Column="0"
                                                       Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,3,6,3"/>
                                            <ComboBox x:Name="cbLlmKvTypeK" Grid.Row="1" Grid.Column="1"
                                                      Style="{StaticResource DarkComboBox}" Margin="0,3,12,3">
                                                <ComboBoxItem Content="F16 (default)"/>
                                                <ComboBoxItem Content="F32"/>
                                                <ComboBoxItem Content="Q8_0"/>
                                                <ComboBoxItem Content="Q4_0"/>
                                            </ComboBox>

                                            <TextBlock Text="KV Type V" Grid.Row="1" Grid.Column="2"
                                                       Foreground="#C8C8D8" FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,3,6,3"/>
                                            <ComboBox x:Name="cbLlmKvTypeV" Grid.Row="1" Grid.Column="3"
                                                      Style="{StaticResource DarkComboBox}" Margin="0,3,0,3">
                                                <ComboBoxItem Content="F16 (default)"/>
                                                <ComboBoxItem Content="F32"/>
                                                <ComboBoxItem Content="Q8_0"/>
                                                <ComboBoxItem Content="Q4_0"/>
                                            </ComboBox>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Use mmap" Foreground="#C8C8D8"
                                                       FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <CheckBox x:Name="chkLlmUseMmap" Foreground="#C8C8D8"
                                                      FontFamily="Consolas" FontSize="10"
                                                      VerticalAlignment="Center"
                                                      Content="keep model pages resident (faster reload, ~5GB RSS)"/>
                                        </StackPanel>
                                        <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="9"
                                                   Foreground="#556677" Margin="0,6,0,0"
                                                   Text="KV constraints: (1) V-cache quantization (Q8_0/Q4_0 V) requires Flash Attention ON — if you pick Q8_0 for V without FA, llama.cpp will refuse to allocate the context. (2) K can always be quantized independently (Q8_0 K + F16 V works with or without FA). (3) mmap OFF frees up to 5GB RAM after GPU upload. Changes apply on next Load."/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button x:Name="btnLlmAutoRecommend" Content="&#x1F3AF; Auto Recommend"
                                            Padding="12,5" Margin="0,0,6,0"
                                            Style="{StaticResource DarkButton}"
                                            ToolTip="Compute safe options based on current GPU/RAM state. Applies to fields only — click Save Options + Load to use."
                                            Click="OnLlmAutoRecommendClick"/>
                                    <Button x:Name="btnLlmSaveOptions" Content="Save Options"
                                            Padding="12,5" Margin="0,0,6,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmSaveOptionsClick"/>
                                    <Button x:Name="btnLlmLoad" Content="Load Model"
                                            Padding="12,5" Margin="0,0,6,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmLoadClick"/>
                                    <Button x:Name="btnLlmUnload" Content="Unload"
                                            Padding="12,5" Margin="0,0,6,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmUnloadClick" IsEnabled="False"/>
                                    <TextBlock x:Name="tbLlmRuntimeState" Text="State: Unloaded"
                                               FontFamily="Consolas" FontSize="10"
                                               Foreground="#556677" VerticalAlignment="Center"
                                               Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Chat Test -->
                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Rectangle Width="3" Height="10" Fill="#00FFAA" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="CHAT TEST (MULTI-TURN SESSION)" FontSize="11" FontWeight="Bold"
                                               Foreground="#00FFAA" FontFamily="Consolas"/>
                                    <TextBlock x:Name="tbLlmTurnCount" Text="turns: 0" FontFamily="Consolas"
                                               FontSize="10" Foreground="#556677" Margin="12,0,0,0"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="btnLlmNewSession" Content="New Session"
                                            Padding="8,2" Margin="12,0,0,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmNewSessionClick" IsEnabled="False"/>
                                </StackPanel>
                                <Border Background="#0A0A14" BorderBrush="#2A2A5E" BorderThickness="1"
                                        Height="180" CornerRadius="2">
                                    <ScrollViewer x:Name="svLlmChat" VerticalScrollBarVisibility="Auto">
                                        <TextBox x:Name="tbLlmChatHistory" IsReadOnly="True"
                                                 TextWrapping="Wrap" AcceptsReturn="True"
                                                 BorderThickness="0" Background="Transparent"
                                                 Foreground="#C8C8D8" FontFamily="Consolas"
                                                 FontSize="10" Padding="8"/>
                                    </ScrollViewer>
                                </Border>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="tbLlmChatInput" Grid.Column="0"
                                             Style="{StaticResource DarkTextBox}"
                                             KeyDown="OnLlmChatInputKeyDown" IsEnabled="False"/>
                                    <Button x:Name="btnLlmChatSend" Grid.Column="1" Content="Send"
                                            Padding="12,5" Margin="8,0,0,0"
                                            Style="{StaticResource DarkButton}"
                                            Click="OnLlmChatSendClick" IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Monitor -->
                        <Border Background="#1A1A2E" BorderBrush="#3E3E42" BorderThickness="1"
                                CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Rectangle Width="3" Height="10" Fill="#FFB800" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="MONITOR" FontSize="11" FontWeight="Bold"
                                               Foreground="#FFB800" FontFamily="Consolas"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Process RAM" FontFamily="Consolas" FontSize="10" Foreground="#556677"/>
                                        <TextBlock x:Name="tbLlmRam" Text="—" FontFamily="Consolas"
                                                   FontSize="14" FontWeight="Bold" Foreground="#00E5FF"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="GPU Memory" FontFamily="Consolas" FontSize="10" Foreground="#556677"/>
                                        <TextBlock x:Name="tbLlmGpu" Text="—" FontFamily="Consolas"
                                                   FontSize="14" FontWeight="Bold" Foreground="#00FFAA"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Tokens/sec (last)" FontFamily="Consolas" FontSize="10" Foreground="#556677"/>
                                        <TextBlock x:Name="tbLlmTps" Text="—" FontFamily="Consolas"
                                                   FontSize="14" FontWeight="Bold" Foreground="#FFB800"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- AgentZero CLI Tab -->
            <TabItem Header="&#x1F4BB; AgentZero CLI" Style="{StaticResource SettingsTabItem}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">

                    <!-- Path Setup -->
                    <Border Background="#1A1A2E" BorderBrush="#3E3E42"
                            BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="3" Height="10" Fill="#FF2D95" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="PATH SETUP" FontSize="11" FontWeight="Bold"
                                           Foreground="#FF2D95" FontFamily="Consolas"/>
                            </StackPanel>
                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#808080" LineHeight="16"
                                       Margin="0,0,0,6">
                                <Run>Register AgentZero CLI path to user PATH environment variable.</Run>
                                <LineBreak/>
                                <Run>After registration, AgentZeroLite.ps1 can be used from anywhere.</Run>
                            </TextBlock>
                            <DockPanel Margin="0,0,0,4">
                                <Button x:Name="btnRegisterPath" DockPanel.Dock="Right"
                                        Content="Register PATH" Padding="14,5"
                                        FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                        Foreground="#00FFF0" Background="#14143A"
                                        BorderBrush="#2A2A5E" BorderThickness="1"
                                        Cursor="Hand" Click="OnRegisterPath"
                                        Margin="8,0,0,0"/>
                                <TextBox x:Name="tbCurrentPath" IsReadOnly="True"
                                         Background="#12122A" Foreground="#556677"
                                         BorderBrush="#2A2A5E" BorderThickness="1"
                                         FontFamily="Consolas" FontSize="10"
                                         Padding="8,4" VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <TextBlock x:Name="lblPathStatus" FontFamily="Consolas" FontSize="10"
                                       Foreground="#556677" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- AI ↔ AI Talk (teach the CLI to Claude / Codex) -->
                    <Border Background="#1A1A2E" BorderBrush="#3E3E42"
                            BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Rectangle Width="3" Height="10" Fill="#8B00FF" RadiusX="1" RadiusY="1" Margin="0,0,6,0"/>
                                <TextBlock Text="AI &#x2194; AI TALK" FontSize="11" FontWeight="Bold"
                                           Foreground="#8B00FF" FontFamily="Consolas"/>
                            </StackPanel>

                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#C8C8D8" LineHeight="16"
                                       Margin="0,0,0,6">
                                <Run FontWeight="Bold" Foreground="#00FFF0">Teach the CLI to your AI once — they can talk to each other forever.</Run>
                            </TextBlock>

                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#808080" LineHeight="16"
                                       Margin="0,0,0,6">
                                <Run>After PATH registration, open a Claude / Codex tab and paste:</Run>
                            </TextBlock>

                            <Border Background="#0A0A14" BorderBrush="#2A2A5E" BorderThickness="1"
                                    CornerRadius="2" Padding="8,6" Margin="0,0,0,8">
                                <TextBox IsReadOnly="True" BorderThickness="0"
                                         Background="Transparent" Foreground="#B5CEA8"
                                         FontFamily="Consolas" FontSize="10"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         Text="Learn `AgentZeroLite.ps1 help` and use it for cross-terminal talk.&#x0a;Use `terminal-list` to see the tabs, `terminal-send &lt;grp&gt; &lt;tab&gt; &quot;text&quot;` to speak to another AI tab by name."/>
                            </Border>

                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#808080" LineHeight="16"
                                       Margin="0,0,0,6">
                                <Run>Then say, for example:</Run>
                            </TextBlock>

                            <Border Background="#0A0A14" BorderBrush="#2A2A5E" BorderThickness="1"
                                    CornerRadius="2" Padding="8,6">
                                <TextBox IsReadOnly="True" BorderThickness="0"
                                         Background="Transparent" Foreground="#C8C8D8"
                                         FontFamily="Consolas" FontSize="10"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         Text="&#x25B8; You (in Claude tab):  Greet the tab named Codex.&#x0a;&#x25B8; Claude runs:           AgentZeroLite.ps1 terminal-send 0 1 &quot;hi Codex, this is Claude&quot;&#x0a;&#x25B8; Codex replies back:    AgentZeroLite.ps1 terminal-send 0 0 &quot;hey Claude, let's design the API&quot;&#x0a;&#x25B8; Each AI reads the peer's reply with: terminal-read 0 &lt;peer-tab&gt; --last 2000"/>
                            </Border>

                            <TextBlock TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"
                                       Foreground="#556677" LineHeight="16"
                                       Margin="0,6,0,0">
                                <Run>No shared memory, no broker — the shell pipes through AgentZero's</Run>
                                <LineBreak/>
                                <Run>IPC (WM_COPYDATA + memory-mapped files). You stay in control.</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
