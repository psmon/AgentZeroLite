<UserControl x:Class="AgentZeroWpf.UI.Components.ScrapPagePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource EditorBg}">
    <!--
        M0019 — Scrap / Window Spy panel ported from AgentZero Origin
        (D:\Code\AI\AgentWin\Project\AgentZeroWpf\UI\APP\MainWindow.xaml lines 654~937).

        Adapted to Lite:
        - Hosted in a UserControl (was inline in Origin's MainWindow) so it can
          live behind the ActivityBar Scrap toggle without polluting MainWindow.
        - Resources resolve via DynamicResource so the UserControl inherits
          MainWindow's color/style dictionary at runtime.
        - The bottom log row + GridSplitter from Origin are intentionally
          omitted — Lite already has a global LOG bottom tab and the in-bot
          log mirror, so a Scrap-local log would duplicate that surface.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- 1: Window Info + Element Tree -->
            <RowDefinition Height="Auto"/>  <!-- 2: Action Bar + Scroll Settings -->
            <RowDefinition Height="*" MinHeight="80"/>  <!-- 3: Captured Text -->
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- Row 0: Toolbar — Crosshair + HWND Input                      -->
        <!-- ============================================================ -->
        <Border Grid.Row="0" Background="{DynamicResource ToolbarBg}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                Padding="10,7">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border x:Name="CrosshairTarget"
                        Width="36" Height="36"
                        Background="{DynamicResource InputBg}"
                        BorderBrush="{DynamicResource CyberCyanBrush}"
                        BorderThickness="1.5"
                        CornerRadius="0"
                        Cursor="Cross"
                        ToolTip="Drag over target window">
                    <Canvas Width="24" Height="24">
                        <Line X1="12" Y1="3" X2="12" Y2="21"
                              Stroke="{DynamicResource CyberCyanBrush}" StrokeThickness="1.5"/>
                        <Line X1="3" Y1="12" X2="21" Y2="12"
                              Stroke="{DynamicResource CyberCyanBrush}" StrokeThickness="1.5"/>
                        <Ellipse Canvas.Left="5" Canvas.Top="5" Width="14" Height="14"
                                 Stroke="{DynamicResource CyberCyanBrush}" StrokeThickness="1.5"/>
                    </Canvas>
                </Border>

                <TextBlock Text="[ TARGET: DRAG ]"
                           Foreground="{DynamicResource TextDim}"
                           VerticalAlignment="Center" FontSize="11"
                           FontFamily="Consolas"
                           Margin="10,0,0,0"/>

                <Border Width="1" Height="20" Margin="16,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="{DynamicResource CyberPurple}" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <TextBlock Text="HWND" Foreground="{DynamicResource CyberCyanBrush}"
                           VerticalAlignment="Center" FontSize="11" FontWeight="Bold"
                           FontFamily="Consolas" Margin="0,0,6,0"/>
                <TextBox x:Name="txtHwnd" Width="140"
                         Style="{DynamicResource DarkTextBox}"
                         KeyDown="OnHwndKeyDown"/>
                <Button x:Name="btnSelect" Content="SELECT"
                        Style="{DynamicResource FlatButton}" Margin="4,0,0,0"
                        Click="OnSelectByHwnd"/>
            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- Row 1: Window Info + Element Tree                             -->
        <!-- ============================================================ -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="ElementTreeColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- Left: WINDOW_INFO -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                        <Rectangle Width="3" Height="10" Fill="{DynamicResource CyberCyanBrush}"
                                   Margin="0,0,6,0" RadiusX="1" RadiusY="1"/>
                        <TextBlock Text="WINDOW_INFO" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource CyberCyanBrush}" FontFamily="Consolas"/>
                    </StackPanel>
                    <TextBox Grid.Row="1" x:Name="txtWindowInfo"
                             Background="{DynamicResource EditorBg}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource InputBorder}"
                             BorderThickness="1"
                             FontFamily="Consolas" FontSize="11.5"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Height="110"
                             Padding="6,4"
                             CaretBrush="{DynamicResource CyberCyanBrush}"
                             SelectionBrush="{DynamicResource SelectionBrush}"
                             Text="Select a window to view info..."/>
                </Grid>

                <!-- Right: ELEMENT_TREE (Flutter / Accessibility) -->
                <Grid x:Name="pnlElementTree" Grid.Column="1" Margin="6,0,0,0" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <Button DockPanel.Dock="Right" Content="SCAN"
                                Style="{DynamicResource SmallButton}"
                                Foreground="{DynamicResource CyberYellowBrush}" FontSize="10"
                                Click="OnRescanTreeClick" ToolTip="Rescan Element Tree"/>
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="3" Height="10" Fill="{DynamicResource CyberYellowBrush}"
                                       Margin="0,0,6,0" RadiusX="1" RadiusY="1"/>
                            <TextBlock x:Name="lblElementTreeTitle" Text="ELEMENT_TREE"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource CyberYellowBrush}" FontFamily="Consolas"/>
                            <TextBlock x:Name="lblElementTreeCount" Text=""
                                       FontSize="10" Foreground="{DynamicResource TextDim}"
                                       FontFamily="Consolas"
                                       Margin="6,0,0,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtTreeSearch" Width="120" Margin="8,0,0,0"
                                     Style="{DynamicResource DarkTextBox}" FontSize="10"
                                     KeyDown="OnTreeSearchKeyDown"
                                     ToolTip="Search (Enter)"/>
                            <TextBlock x:Name="lblTreeSearchResult" Text=""
                                       FontSize="10"
                                       Foreground="{DynamicResource CyberMagentaBrush}"
                                       FontFamily="Consolas"
                                       Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBox x:Name="txtElementTree" Grid.Row="1"
                             Background="{DynamicResource EditorBg}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource InputBorder}"
                             BorderThickness="1"
                             FontFamily="Consolas" FontSize="11"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Height="110"
                             Padding="4,2"
                             CaretBrush="{DynamicResource CyberCyanBrush}"
                             SelectionBrush="{DynamicResource SelectionBrush}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- Row 2: Action Bar + Scroll Settings                           -->
        <!-- ============================================================ -->
        <Border Grid.Row="2" Background="{DynamicResource ToolbarBg}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="btnCapture" Content="▶  CAPTURE"
                            Style="{DynamicResource AccentButton}" Padding="14,5"
                            Click="OnCaptureClick"/>
                    <Button x:Name="btnClear" Content="CLR"
                            Style="{DynamicResource FlatButton}" Margin="6,0,0,0"
                            Click="OnClearClick"/>
                    <Button x:Name="btnCopy" Content="CPY"
                            Style="{DynamicResource FlatButton}" Margin="4,0,0,0"
                            Click="OnCopyClick"/>
                    <Button x:Name="btnOpenDir" Content="DIR"
                            Style="{DynamicResource FlatButton}" Margin="4,0,0,0"
                            Click="OnOpenDirClick"/>
                    <Button x:Name="btnConsole" Content="PS"
                            Style="{DynamicResource FlatButton}" Margin="4,0,0,0"
                            ToolTip="Open PowerShell Console"
                            Click="OnConsoleClick"/>
                </StackPanel>

                <TextBlock x:Name="lblCaptureStatus" Grid.Column="1"
                           Text="READY" Foreground="{DynamicResource TextDim}"
                           VerticalAlignment="Center" FontSize="11"
                           FontFamily="Consolas"
                           Margin="14,0" TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="RANGE" Foreground="{DynamicResource TextDim}"
                               FontSize="10" FontFamily="Consolas"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <DatePicker x:Name="dpFilterStart" Width="110"
                                FontSize="11" SelectedDateFormat="Short"
                                ToolTip="Start Date"/>
                    <TextBlock Text="~" Foreground="{DynamicResource CyberMagentaBrush}"
                               FontSize="12" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="3,0,3,0"/>
                    <DatePicker x:Name="dpFilterEnd" Width="110"
                                FontSize="11" SelectedDateFormat="Short"
                                ToolTip="End Date"/>

                    <Border Width="1" Height="16" Margin="8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="{DynamicResource CyberPurple}" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <TextBlock Text="DLY" Foreground="{DynamicResource TextDim}"
                               FontSize="10" FontFamily="Consolas"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="txtScrollDelay" Width="48" Text="200"
                             Style="{DynamicResource DarkTextBox}" FontSize="11"
                             PreviewTextInput="OnNumericInput"
                             ToolTip="Scroll Delay (ms)"/>

                    <TextBlock Text="MAX" Foreground="{DynamicResource TextDim}"
                               FontSize="10" FontFamily="Consolas"
                               VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox x:Name="txtMaxAttempts" Width="48" Text="500"
                             Style="{DynamicResource DarkTextBox}" FontSize="11"
                             PreviewTextInput="OnNumericInput"
                             ToolTip="Max Scroll Attempts"/>

                    <TextBlock Text="DLT" Foreground="{DynamicResource TextDim}"
                               FontSize="10" FontFamily="Consolas"
                               VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox x:Name="txtScrollDelta" Width="36" Text="3"
                             Style="{DynamicResource DarkTextBox}" FontSize="11"
                             PreviewTextInput="OnNumericInput"
                             ToolTip="Wheel Delta Multiplier"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============================================================ -->
        <!-- Row 3: Captured Text                                          -->
        <!-- ============================================================ -->
        <Border Grid.Row="3" Margin="4,2,4,4">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{DynamicResource CyberBorderDim}" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <TextBox x:Name="txtCapturedText"
                     Background="{DynamicResource EditorBg}"
                     Foreground="{DynamicResource TextPrimary}"
                     BorderThickness="0"
                     FontFamily="Consolas" FontSize="12"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Padding="8,4"
                     CaretBrush="{DynamicResource CyberCyanBrush}"
                     SelectionBrush="{DynamicResource SelectionBrush}"/>
        </Border>
    </Grid>
</UserControl>
