<UserControl x:Class="AgentZeroWpf.UI.Components.DocumentViewerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:components="clr-namespace:AgentZeroWpf.UI.Components"
             Background="#1E1E1E">

    <UserControl.Resources>
        <SolidColorBrush x:Key="DocBg"         Color="#1E1E1E"/>
        <SolidColorBrush x:Key="DocToolbar"    Color="#2D2D30"/>
        <SolidColorBrush x:Key="DocBorder"     Color="#3E3E42"/>
        <SolidColorBrush x:Key="DocAccent"     Color="#3794FF"/>
        <SolidColorBrush x:Key="DocText"       Color="#D4D4D4"/>
        <SolidColorBrush x:Key="DocDim"        Color="#858585"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource DocToolbar}"
                BorderBrush="{StaticResource DocBorder}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <DockPanel>
                <!-- Right: mode toggles -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <!-- Browser open buttons (HTML only) -->
                    <StackPanel x:Name="pnlBrowserButtons" Orientation="Horizontal"
                                Visibility="Collapsed" Margin="0,0,8,0">
                        <Rectangle Width="1" Height="14" Fill="{StaticResource DocBorder}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button x:Name="btnOpenEdge" Visibility="Collapsed"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="4,2" Margin="2,0"
                                ToolTip="Open in Edge" Click="OnOpenInEdge">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" Foreground="#0078D4"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" Edge" FontSize="9" Foreground="{StaticResource DocDim}"
                                           FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="btnOpenChrome" Visibility="Collapsed"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="4,2" Margin="2,0"
                                ToolTip="Open in Chrome" Click="OnOpenInChrome">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="13" Foreground="#4285F4"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" Chrome" FontSize="9" Foreground="{StaticResource DocDim}"
                                           FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Button x:Name="btnEdit" Content="&#xE70F;"
                            FontFamily="Segoe MDL2 Assets" FontSize="13"
                            Foreground="{StaticResource DocDim}" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" Padding="8,3" Margin="2,0"
                            Click="OnEditClick" ToolTip="Edit Mode"/>
                    <Button x:Name="btnView" Content="&#xE890;"
                            FontFamily="Segoe MDL2 Assets" FontSize="13"
                            Foreground="{StaticResource DocAccent}" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" Padding="8,3" Margin="2,0"
                            Click="OnViewClick" ToolTip="View Mode"/>
                    <Button x:Name="btnSave" Content="&#xE74E;"
                            FontFamily="Segoe MDL2 Assets" FontSize="13"
                            Foreground="{StaticResource DocDim}" Background="Transparent"
                            BorderThickness="0" Cursor="Hand" Padding="8,3" Margin="2,0"
                            Click="OnSaveClick" ToolTip="Save" Visibility="Collapsed"/>
                </StackPanel>

                <!-- Left: file info -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="txtFileIcon" Text="&#xE7C3;"
                               FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{StaticResource DocAccent}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtFileName" Text="No file selected"
                               FontSize="11" Foreground="{StaticResource DocText}"
                               FontFamily="Consolas" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content area -->
        <Grid x:Name="contentArea" Grid.Row="1">
            <!-- Empty state -->
            <TextBlock x:Name="txtEmpty" Text="Select a file to view"
                       FontSize="14" Foreground="#858585" FontFamily="Consolas"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Markdown rendered view -->
            <components:MarkdownViewer x:Name="mdViewer" Visibility="Collapsed"/>

            <!-- Raw text editor (for md edit mode) -->
            <avalonEdit:TextEditor x:Name="txtEditor" Visibility="Collapsed"
                                   Background="{StaticResource DocBg}" Foreground="{StaticResource DocText}"
                                   FontFamily="Consolas" FontSize="12"
                                   ShowLineNumbers="True" WordWrap="False"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   IsReadOnly="False"/>

            <!-- Code viewer (read-only AvalonEdit) -->
            <avalonEdit:TextEditor x:Name="codeViewer" Visibility="Collapsed"
                                   Background="{StaticResource DocBg}" Foreground="{StaticResource DocText}"
                                   FontFamily="Consolas" FontSize="12"
                                   ShowLineNumbers="True" WordWrap="False"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   IsReadOnly="True"/>

            <!-- Image viewer -->
            <ScrollViewer x:Name="svImage" Visibility="Collapsed"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource DocBg}">
                <Image x:Name="imgView" Stretch="None"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ScrollViewer>

            <!-- PDF viewer (pages as images) -->
            <ScrollViewer x:Name="svPdf" Visibility="Collapsed"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource DocBg}">
                <StackPanel x:Name="pnlPdfPages" Orientation="Vertical"
                            HorizontalAlignment="Center"/>
            </ScrollViewer>

            <!-- Mermaid SVG viewer -->
            <ScrollViewer x:Name="svMermaid" Visibility="Collapsed"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource DocBg}">
                <svgc:SvgViewbox x:Name="svgMermaid"
                    xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
                    Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ScrollViewer>

            <!-- Unsupported file -->
            <TextBlock x:Name="txtUnsupported" Visibility="Collapsed"
                       Text="Binary file — preview not available"
                       FontSize="13" Foreground="#858585" FontFamily="Consolas"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
