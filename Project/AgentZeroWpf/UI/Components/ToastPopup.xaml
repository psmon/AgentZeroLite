<UserControl x:Class="AgentZeroWpf.UI.Components.ToastPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">

    <Border x:Name="toastBorder" Background="#2D2D30" BorderBrush="#3794FF"
            BorderThickness="1" CornerRadius="0" Padding="14,7"
            Opacity="0">
        
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="txtIcon" Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                       FontSize="12" Foreground="#3794FF" VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <TextBlock x:Name="txtMessage" Text="" FontSize="11"
                       Foreground="#D4D4D4" FontFamily="Consolas"
                       VerticalAlignment="Center" MaxWidth="400"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>
    </Border>
</UserControl>
