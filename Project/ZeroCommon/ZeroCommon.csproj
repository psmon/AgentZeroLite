<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Agent.Common</RootNamespace>
    <AssemblyName>Agent.Common</AssemblyName>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Akka" Version="1.5.40" />
    <PackageReference Include="Akka.DependencyInjection" Version="1.5.40" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.0-preview.3.25171.6" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.0-preview.3.25171.6">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <!-- OnDevice LLamaSharp was removed 2026-04-18 due to ggml.dll conflict with
         Whisper.net — both bundle their own ggml and reuse whichever loads first,
         breaking the second. Local LLM now goes exclusively through Ollama.
         See SciSharp/LLamaSharp#974 + Docs/LLM/DotNet-Integration.md. -->
  </ItemGroup>

</Project>
